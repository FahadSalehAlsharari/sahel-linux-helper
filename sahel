_cli_version() {
    echo "${SAHEL_NAME_AR} (${SAHEL_NAME}) v${SAHEL_VERSION} -- ${SAHEL_AUTHOR} (${SAHEL_SITE})"
}

# ----------------------------------------------------------------------------
#  SECTION 13: main_menu
#  القائمة الرئيسية والتشغيل
# ----------------------------------------------------------------------------

_main_menu() {
    while true; do
        _header

        echo ""
        echo -e "  ${C_BOLD}القائمة الرئيسية${C_RESET}"
        echo ""
        echo -e "  ${C_WHITE}1${C_RESET} -- تحديث النظام الشامل"
        echo -e "  ${C_WHITE}2${C_RESET} -- تنظيف النظام"
        echo -e "  ${C_WHITE}3${C_RESET} -- ادارة البرامج المثبتة"
        echo -e "  ${C_WHITE}4${C_RESET} -- تثبيت برامج جديدة"
        echo -e "  ${C_WHITE}5${C_RESET} -- معلومات النظام"
        echo -e "  ${C_WHITE}6${C_RESET} -- تحديث ${SAHEL_NAME_AR}"
        echo ""
        _line '-'
        echo -e "  ${C_WHITE}0${C_RESET} -- خروج"
        echo ""
        echo -ne "  الاختيار: "

        read -r choice

        case "$choice" in
            1) _mod_update ;;
            2) _mod_cleanup ;;
            3) _mod_packages ;;
            4) _mod_install ;;
            5) _sysinfo_display ;;
            6) _mod_self_update ;;
            0)
                echo ""
                _ok "شكرا لاستخدامك ${SAHEL_NAME_AR}"
                _info "${SAHEL_AUTHOR} -- ${SAHEL_SITE}"
                _log "INFO" "خروج عادي"
                echo ""
                exit 0
                ;;
            *)
                _warn "اختيار غير صحيح"
                sleep 1
                ;;
        esac
    done
}

# ============================================================================
#  نقطة الدخول
# ============================================================================

main() {
    # --- تهيئة الواجهة ---
    _ui_init_colors
    _ui_detect_icon_mode
    _safety_check_locale
    _safety_load_os_release

    # --- Trap ---
    trap _trap_cleanup EXIT
    trap _trap_interrupt INT TERM

    # --- معالجة الخيارات ---
    local action=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                _cli_help
                exit 0
                ;;
            --version|-v)
                _cli_version
                exit 0
                ;;
            --dry-run)
                SAHEL_DRY_RUN=1
                shift
                ;;
            --update)
                action="update"
                shift
                ;;
            --clean)
                action="clean"
                shift
                ;;
            --info)
                action="info"
                shift
                ;;
            --self-update)
                action="self-update"
                shift
                ;;
            *)
                _err "خيار غير معروف: ${1}"
                _cli_help
                exit 1
                ;;
        esac
    done

    # --- تنفيذ الاجراء ---
    case "$action" in
        update)
            _safety_check_sudo
            _log_init
            _log_rotate
            _log "INFO" "=== جلسة: تحديث سريع $(( SAHEL_DRY_RUN )) ==="
            _safety_check_distro
            _mod_update
            exit 0
            ;;
        clean)
            _safety_check_sudo
            _log_init
            _log_rotate
            _log "INFO" "=== جلسة: تنظيف سريع ==="
            _safety_check_distro
            _mod_cleanup
            exit 0
            ;;
        info)
            _log_init
            _sysinfo_display
            exit 0
            ;;
        self-update)
            _log_init
            _mod_self_update
            exit 0
            ;;
        "")
            # الوضع التفاعلي
            ;;
    esac

    # --- الوضع التفاعلي ---
    _safety_check_sudo
    _log_init
    _log_rotate
    _log "INFO" "=== بدء جلسة تفاعلية ==="
    _safety_check_distro
    _main_menu
}

main "$@"
