# ========================================
#  تنظيف النظام
# ========================================
_mod_cleanup() {
    _header
    _section "تنظيف النظام"

    local total_freed=0
    local before after freed

    # --- 1. حزم يتيمة ---
    _info "فحص الحزم اليتيمة..."
    local orphans
    orphans=$(_apt_orphan_count)

    if (( orphans > 0 )); then
        _warn "${orphans} حزمة يتيمة"
        if _confirm "حذف الحزم اليتيمة؟"; then
            before=$(df / --output=avail -B1 2>/dev/null | tail -1 | tr -d ' ')
            _apt_autoremove
            after=$(df / --output=avail -B1 2>/dev/null | tail -1 | tr -d ' ')
            freed=$(( after - before ))
            (( freed > 0 )) && total_freed=$(( total_freed + freed ))
        fi
    else
        _ok "لا توجد حزم يتيمة"
    fi

    # --- 2. كاش apt ---
    echo ""
    _info "فحص كاش الحزم..."
    local csz
    csz=$(_apt_cache_size)

    if (( csz > 1048576 )); then
        _info "حجم الكاش: $(_human_size "$csz")"
        if _confirm "تنظيف كاش apt؟"; then
            before=$(df / --output=avail -B1 2>/dev/null | tail -1 | tr -d ' ')
            _apt_clean_cache
            after=$(df / --output=avail -B1 2>/dev/null | tail -1 | tr -d ' ')
            freed=$(( after - before ))
            (( freed > 0 )) && total_freed=$(( total_freed + freed ))
        fi
    else
        _ok "الكاش نظيف"
    fi

    # --- 3. سجلات journal ---
    echo ""
    _info "فحص سجلات النظام (journal)..."
    if _has_cmd journalctl; then
        local jsz
        jsz=$(journalctl --disk-usage 2>/dev/null | grep -oP '[\d.]+[GMK]' | head -1 || echo "")
        if [[ -n "$jsz" ]]; then
            _info "حجم السجلات: ${jsz}"
            if _confirm "حذف السجلات الاقدم من 7 ايام؟"; then
                before=$(df / --output=avail -B1 2>/dev/null | tail -1 | tr -d ' ')
                _as_root journalctl --vacuum-time=7d --quiet 2>/dev/null
                after=$(df / --output=avail -B1 2>/dev/null | tail -1 | tr -d ' ')
                freed=$(( after - before ))
                (( freed > 0 )) && total_freed=$(( total_freed + freed ))
                _ok "تم تنظيف السجلات القديمة"
            fi
        fi
    else
        _ok "journalctl غير متوفر -- تخطي"
    fi

    # --- 4. ملفات مؤقتة قديمة ---
    echo ""
    _info "فحص الملفات المؤقتة (/tmp)..."
    local tmp_c
    tmp_c=$(find /tmp -type f -atime +7 2>/dev/null | wc -l || echo "0")

    if (( tmp_c > 0 )); then
        _info "${tmp_c} ملف مؤقت اقدم من 7 ايام"
        if _confirm "حذف الملفات المؤقتة القديمة؟"; then
            before=$(df / --output=avail -B1 2>/dev/null | tail -1 | tr -d ' ')
            find /tmp -type f -atime +7 -delete 2>/dev/null || true
            after=$(df / --output=avail -B1 2>/dev/null | tail -1 | tr -d ' ')
            freed=$(( after - before ))
            (( freed > 0 )) && total_freed=$(( total_freed + freed ))
            _ok "تم حذف الملفات المؤقتة"
        fi
    else
        _ok "لا توجد ملفات مؤقتة قديمة"
    fi

    # --- 5. thumbnails ---
    echo ""
    local real_user="${SUDO_USER:-$USER}"
    local thumb_dir="/home/${real_user}/.cache/thumbnails"
    if [[ -d "$thumb_dir" ]]; then
        local tsz
        tsz=$(du -sb "$thumb_dir" 2>/dev/null | awk '{print $1}' || echo "0")
        if (( tsz > 5242880 )); then
            _info "حجم الصور المصغرة: $(_human_size "$tsz")"
            if _confirm "حذف كاش الصور المصغرة؟"; then
                before=$(df / --output=avail -B1 2>/dev/null | tail -1 | tr -d ' ')
                rm -rf "${thumb_dir:?}"/* 2>/dev/null || true
                after=$(df / --output=avail -B1 2>/dev/null | tail -1 | tr -d ' ')
                freed=$(( after - before ))
                (( freed > 0 )) && total_freed=$(( total_freed + freed ))
                _ok "تم حذف الصور المصغرة"
            fi
        else
            _ok "كاش الصور المصغرة صغير"
        fi
    fi

    # --- 6. snap قديمة ---
    if _snap_available; then
        echo ""
        _info "فحص نسخ Snap القديمة..."
        local old_snaps
        old_snaps=$(_snap_old_revisions_count)
        if (( old_snaps > 0 )); then
            _info "${old_snaps} نسخة Snap قديمة"
            if _confirm "حذف نسخ Snap القديمة؟"; then
                before=$(df / --output=avail -B1 2>/dev/null | tail -1 | tr -d ' ')
                _snap_clean_old
                after=$(df / --output=avail -B1 2>/dev/null | tail -1 | tr -d ' ')
                freed=$(( after - before ))
                (( freed > 0 )) && total_freed=$(( total_freed + freed ))
            fi
        else
            _ok "لا توجد نسخ Snap قديمة"
        fi
    fi

    # --- الملخص ---
    echo ""
    _line '='
    if (( total_freed > 0 )); then
        _ok "المساحة المسترجعة: $(_human_size "$total_freed")"
    else
        _ok "التنظيف اكتمل"
    fi
    _log "INFO" "تنظيف النظام -- اكتمل (${total_freed} bytes)"
    _pause
}

# ========================================
#  ادارة البرامج المثبتة
# ========================================
_mod_packages() {
    while true; do
        _header
        _section "ادارة البرامج المثبتة"

        echo ""
        echo -e "  ${C_WHITE}1${C_RESET} -- عرض برامج apt (المثبتة يدويا)"
        echo -e "  ${C_WHITE}2${C_RESET} -- عرض برامج Snap"
        echo -e "  ${C_WHITE}3${C_RESET} -- عرض برامج Flatpak"
        echo -e "  ${C_WHITE}4${C_RESET} -- البحث في البرامج المثبتة"
        echo -e "  ${C_WHITE}5${C_RESET} -- حذف برنامج"
        echo ""
        echo -e "  ${C_WHITE}0${C_RESET} -- رجوع"
        echo ""
        echo -ne "  الاختيار: "
        read -r c

        case "$c" in
            1) _pkg_list_apt ;;
            2) _pkg_list_snap ;;
            3) _pkg_list_flatpak ;;
            4) _pkg_search ;;
            5) _pkg_remove ;;
            0) return ;;
            *) _warn "اختيار غير صحيح"; sleep 1 ;;
        esac
    done
}

_pkg_list_apt() {
    local packages
    packages=$(_apt_list_manual)
    local total
    total=$(echo "$packages" | wc -l)
    local page_size=25 page=1
    local total_pages=$(( (total + page_size - 1) / page_size ))

    while true; do
        _header
        _section "البرامج المثبتة يدويا (apt)"
        _info "الاجمالي: ${total} -- صفحة ${page}/${total_pages}"
        echo ""

        local start=$(( (page - 1) * page_size + 1 ))
        local end=$(( page * page_size ))

        echo "$packages" | sed -n "${start},${end}p" | nl -ba -s'  ' -w3 -v "$start" | while IFS= read -r line; do
            echo -e "    ${C_DIM}${line}${C_RESET}"
        done

        echo ""
        echo -e "  ${C_DIM}[n] التالي  [p] السابق  [0] رجوع${C_RESET}"
        echo -ne "  : "
        read -r nav

        case "$nav" in
            [نtn]) (( page < total_pages )) && (( page++ )) ;;
            [سpb]) (( page > 1 )) && (( page-- )) ;;
            0|q) return ;;
        esac
    done
}

_pkg_list_snap() {
    _header
    _section "البرامج المثبتة (Snap)"

    if ! _snap_available; then
        _info "Snap غير مثبت"
