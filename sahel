set -euo pipefail

# ----------------------------------------------------------------------------
#  SECTION 01: config
#  الاعدادات العامة والثوابت
# ----------------------------------------------------------------------------

readonly SAHEL_VERSION="2.0.0"
readonly SAHEL_NAME="sahel"
readonly SAHEL_NAME_AR="سهل"
readonly SAHEL_AUTHOR="FahadAlsharari"
readonly SAHEL_SITE="FahadAlsharari.sa"
readonly SAHEL_REPO="https://github.com/FahadAlsharari/sahel"
readonly SAHEL_LOG_DIR="/var/log/sahel"
readonly SAHEL_LOG_FILE="${SAHEL_LOG_DIR}/sahel.log"
readonly SAHEL_CONF_DIR="/etc/sahel"
readonly SAHEL_POPULAR_CONF="${SAHEL_CONF_DIR}/popular.conf"

# وضع الرموز: ascii (افتراضي آمن) او fancy (يحتاج دعم Unicode)
SAHEL_ICON_MODE="ascii"

# وضع المحاكاة: لو 1 ما ينفذ شي فعلي (--dry-run)
SAHEL_DRY_RUN=0

# متغيرات os-release -- تُملأ مرة واحدة عند التهيئة
_OS_ID=""
_OS_PRETTY=""

# الحزم المحمية من الحذف - حذف اي وحدة منها يدمر النظام
readonly PROTECTED_PACKAGES=(
    "ubuntu-minimal" "ubuntu-standard" "ubuntu-desktop"
    "ubuntu-desktop-minimal" "base-files" "bash" "coreutils"
    "dpkg" "apt" "systemd" "init" "linux-base" "linux-generic"
    "linux-image-generic" "grub-common" "grub-efi" "grub-pc"
    "sudo" "passwd" "login" "mount" "util-linux"
    "libc6" "libstdc++6" "libgcc-s1" "zlib1g"
    "network-manager" "networkd-dispatcher"
    "dbus" "udev" "kmod" "adduser"
    "apt-utils" "dpkg-dev" "gnupg" "gpgv"
)

# ----------------------------------------------------------------------------
#  SECTION 02: ui
#  الالوان والرموز ودوال الواجهة
# ----------------------------------------------------------------------------

# --- كشف دعم الالوان ---
_ui_init_colors() {
    if [[ -t 1 ]] && command -v tput &>/dev/null && [[ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]]; then
        C_RESET='\033[0m'
        C_BOLD='\033[1m'
        C_DIM='\033[2m'
        C_RED='\033[31m'
        C_GREEN='\033[32m'
        C_YELLOW='\033[33m'
        C_BLUE='\033[34m'
        C_CYAN='\033[36m'
        C_WHITE='\033[1;37m'
        C_BG_RED='\033[41m'
    else
        C_RESET='' C_BOLD='' C_DIM='' C_RED='' C_GREEN=''
        C_YELLOW='' C_BLUE='' C_CYAN='' C_WHITE='' C_BG_RED=''
    fi
}

# --- كشف دعم Unicode ---
_ui_detect_icon_mode() {
    # لو المستخدم حدد بنفسه عبر متغير بيئة -- نحترم اختياره
    if [[ "${SAHEL_FANCY:-}" == "1" ]]; then
        SAHEL_ICON_MODE="fancy"
        return
    fi
    # الافتراضي دائماً ascii -- الاكثر توافقاً
    SAHEL_ICON_MODE="ascii"
}

# --- الرموز حسب الوضع ---
_icon() {
    local name="${1:-default}"
    if [[ "$SAHEL_ICON_MODE" == "fancy" ]]; then
        case "$name" in
            ok)    printf "\xe2\x9c\x93" ;;
            fail)  printf "\xe2\x9c\x97" ;;
            warn)  printf "!"  ;;
            info)  printf "i"  ;;
            dry)   printf "~"  ;;
            *)     printf "*"  ;;
        esac
    else
        case "$name" in
            ok)    printf "[OK]"  ;;
            fail)  printf "[X]"   ;;
            warn)  printf "[!]"   ;;
            info)  printf "[i]"   ;;
            dry)   printf "[DRY]" ;;
            *)     printf "[-]"   ;;
        esac
    fi
}

# --- عرض الطرفية ---
_term_width() {
    local w
    w=$(tput cols 2>/dev/null || echo 70)
    (( w < 40 )) && w=40
    (( w > 100 )) && w=100
    echo "$w"
}

# --- فاصل افقي آمن (ASCII فقط) ---
_line() {
    local char="${1:--}" len="${2:-0}"
    if (( len == 0 )); then
        len=$(( $(_term_width) - 4 ))
    fi
    printf '  '
    printf '%*s' "$len" '' | tr ' ' "$char"
    printf '\n'
}

# --- دوال الطباعة ---
_ok() {
    echo -e "  ${C_GREEN}$(_icon ok)${C_RESET} $1"
}

_err() {
    echo -e "  ${C_RED}$(_icon fail)${C_RESET} $1" >&2
}

_warn() {
    echo -e "  ${C_YELLOW}$(_icon warn)${C_RESET} $1"
}

_info() {
    echo -e "  ${C_CYAN}$(_icon info)${C_RESET} $1"
}

_dry() {
    echo -e "  ${C_YELLOW}$(_icon dry)${C_RESET} ${C_DIM}(محاكاة)${C_RESET} $1"
}

# --- عنوان قسم ---
_section() {
    echo ""
    echo -e "  ${C_BOLD}${C_BLUE}$1${C_RESET}"
    _line '-'
}

# --- مسح الشاشة + الترويسة ---
_header() {
    clear 2>/dev/null || printf '\033[2J\033[H'
    echo ""
    _line '='
    echo -e "  ${C_BOLD}${C_WHITE}${SAHEL_NAME_AR} (${SAHEL_NAME}) v${SAHEL_VERSION}${C_RESET}"
    echo -e "  ${C_DIM}${SAHEL_AUTHOR} -- ${SAHEL_SITE}${C_RESET}"
    if (( SAHEL_DRY_RUN )); then
        echo -e "  ${C_YELLOW}${C_BOLD}-- وضع المحاكاة (dry-run) -- لا يتم تنفيذ اي تغيير فعلي --${C_RESET}"
    fi
    _line '='
}

# --- طلب تأكيد ---
_confirm() {
    local msg="$1"
    echo ""
    echo -e "  ${C_YELLOW}$(_icon warn) ${msg}${C_RESET}"
    echo -ne "  المتابعة؟ (ن/ل) [ل]: "
    local answer
    read -r answer
    case "$answer" in
        [نyY]|نعم|yes|YES) return 0 ;;
        *) return 1 ;;
    esac
}

# --- تأكيد مزدوج للعمليات الخطيرة ---
_confirm_danger() {
    local msg="$1"
    echo ""
    echo -e "  ${C_BG_RED}${C_WHITE}${C_BOLD} تحذير ${C_RESET}"
    echo -e "  ${C_RED}${msg}${C_RESET}"
    echo -ne "  اكتب '${C_WHITE}نعم${C_RESET}' بالضبط للتأكيد: "
    local answer
    read -r answer
    [[ "$answer" == "نعم" || "$answer" == "yes" ]]
}

# --- انتظار ---
_pause() {
    echo ""
    echo -ne "  ${C_DIM}[Enter] للرجوع...${C_RESET}"
    read -r
}

# --- حجم مقروء ---
_human_size() {
    local bytes="${1:-0}"
    if (( bytes >= 1073741824 )); then
        awk "BEGIN{printf \"%.1f GB\", ${bytes}/1073741824}"
    elif (( bytes >= 1048576 )); then
        awk "BEGIN{printf \"%.1f MB\", ${bytes}/1048576}"
    elif (( bytes >= 1024 )); then
        awk "BEGIN{printf \"%.1f KB\", ${bytes}/1024}"
    else
        printf "%d B" "$bytes"
    fi
}

# --- تحقق من ان المدخل رقم صحيح ---
_is_int() {
    [[ "${1:-}" =~ ^[0-9]+$ ]]
}

# ----------------------------------------------------------------------------
#  SECTION 03: logging
#  نظام التسجيل
# ----------------------------------------------------------------------------

_log_init() {
    if [[ ! -d "$SAHEL_LOG_DIR" ]]; then
        sudo mkdir -p "$SAHEL_LOG_DIR" 2>/dev/null || {
            _warn "تعذر انشاء مجلد السجلات: ${SAHEL_LOG_DIR}"
            return 1
        }
        sudo chmod 750 "$SAHEL_LOG_DIR" 2>/dev/null || true
    fi
    # نتأكد ان المستخدم الحالي يقدر يكتب
    if [[ ! -w "$SAHEL_LOG_DIR" ]]; then
        sudo chown "$(id -u):$(id -g)" "$SAHEL_LOG_DIR" 2>/dev/null || true
    fi
    # ضبط صلاحيات ملف السجل -- 640 فقط المالك يقرأ ويكتب والمجموعة تقرأ
    if [[ ! -f "$SAHEL_LOG_FILE" ]]; then
        touch "$SAHEL_LOG_FILE" 2>/dev/null || true
        chmod 640 "$SAHEL_LOG_FILE" 2>/dev/null || true
    fi
}

_log() {
    local level="$1" message="$2"
    local ts
    ts="$(date '+%Y-%m-%d %H:%M:%S')"
    printf '[%s] [%-5s] %s\n' "$ts" "$level" "$message" >> "$SAHEL_LOG_FILE" 2>/dev/null || true
}

# --- تدوير السجلات اذا تجاوز 10MB ---
_log_rotate() {
    if [[ -f "$SAHEL_LOG_FILE" ]]; then
        local sz
        sz=$(stat -c%s "$SAHEL_LOG_FILE" 2>/dev/null || echo 0)
        if (( sz > 10485760 )); then
            mv "$SAHEL_LOG_FILE" "${SAHEL_LOG_FILE}.1" 2>/dev/null || true
            gzip -f "${SAHEL_LOG_FILE}.1" 2>/dev/null || true
            touch "$SAHEL_LOG_FILE" 2>/dev/null || true
            chmod 640 "$SAHEL_LOG_FILE" 2>/dev/null || true
            _log "INFO" "تم تدوير ملف السجل"
        fi
    fi
}

# ----------------------------------------------------------------------------
#  SECTION 04: safety
#  فحوصات الامان وحماية النظام
# ----------------------------------------------------------------------------

# تحميل معلومات التوزيعة مرة واحدة فقط
_safety_load_os_release() {
    if [[ -f /etc/os-release ]]; then
        # استخراج آمن بدون source كامل
        _OS_ID=$(grep '^ID=' /etc/os-release | cut -d= -f2 | tr -d '"' || echo "unknown")
        _OS_PRETTY=$(grep '^PRETTY_NAME=' /etc/os-release | cut -d= -f2- | tr -d '"' || echo "غير معروف")
    else
        _OS_ID="unknown"
        _OS_PRETTY="غير معروف"
    fi
}

# فحص التوزيعة
_safety_check_distro() {
    if [[ -z "$_OS_ID" ]]; then
        _safety_load_os_release
    fi

    case "$_OS_ID" in
        ubuntu|debian|linuxmint|pop|zorin|elementary|neon)
            _log "INFO" "التوزيعة: ${_OS_PRETTY}"
            ;;
        *)
            _warn "التوزيعة (${_OS_PRETTY}) غير مختبرة بالكامل"
            _info "الاداة مصممة لتوزيعات Debian/Ubuntu"
            if ! _confirm "تريد الاستمرار؟"; then
                exit 0
            fi
            ;;
    esac
}

# فحص هل المستخدم يملك sudo
_safety_check_sudo() {
    if [[ "$(id -u)" -eq 0 ]]; then
        return 0
    fi
    if ! sudo -n true 2>/dev/null; then
        _info "بعض العمليات تحتاج صلاحيات مدير النظام"
        if ! sudo true 2>/dev/null; then
            _err "تعذر الحصول على صلاحيات sudo"
            exit 1
        fi
    fi
}

# تنفيذ امر بصلاحيات root فقط عند الحاجة
# في وضع dry-run يطبع الامر فقط بدون تنفيذ
_as_root() {
    if (( SAHEL_DRY_RUN )); then
        _dry "سيتم تنفيذ: $*"
        return 0
    fi
    if [[ "$(id -u)" -eq 0 ]]; then
        "$@"
    else
        sudo "$@"
    fi
}

# هل الحزمة محمية؟
_is_protected() {
    local pkg="$1"
    local p
    for p in "${PROTECTED_PACKAGES[@]}"; do
        [[ "$pkg" == "$p" ]] && return 0
    done
    return 1
}

# هل امر معين موجود؟
_has_cmd() {
    command -v "$1" &>/dev/null
}

# فحص locale
_safety_check_locale() {
    local current_lc="${LC_ALL:-${LANG:-}}"

    if [[ -z "$current_lc" ]]; then
        if locale -a 2>/dev/null | grep -qi 'en_US.utf8\|en_US.UTF-8'; then
            export LANG="en_US.UTF-8"
        fi
    fi

    if [[ "${current_lc,,}" != *utf-8* && "${current_lc,,}" != *utf8* ]]; then
        if locale -a 2>/dev/null | grep -qi 'utf-8\|utf8'; then
            export LC_ALL="en_US.UTF-8" 2>/dev/null || true
        fi
    fi
}

# التحقق من صلاحية اسم الحزمة (منع الحقن)
_validate_pkg_name() {
    local pkg="$1"
    # اسم الحزمة: حروف صغيرة، ارقام، نقاط، شرطات، زائد
    if [[ ! "$pkg" =~ ^[a-z0-9][a-z0-9.+\-]*$ ]]; then
        _err "اسم حزمة غير صالح: ${pkg}"
        _log "WARN" "اسم حزمة مرفوض (validation): ${pkg}"
        return 1
    fi
    # الحد الاقصى 128 حرف
    if (( ${#pkg} > 128 )); then
        _err "اسم الحزمة طويل جدا"
        return 1
    fi
    return 0
}

# ----------------------------------------------------------------------------
#  SECTION 05: trap
#  معالجة الاشارات والخروج
# ----------------------------------------------------------------------------

_trap_cleanup() {
    local code=$?
    if [[ $code -ne 0 && $code -ne 130 ]]; then
        _log "WARN" "خروج غير طبيعي بكود: ${code}"
    fi
    _log "INFO" "--- انتهاء الجلسة ---"
    tput cnorm 2>/dev/null || true
    stty echo 2>/dev/null || true
}

_trap_interrupt() {
    echo ""
    _info "تم الالغاء"
    exit 130
}

# ----------------------------------------------------------------------------
#  SECTION 06: apt
#  عمليات مدير الحزم apt
# ----------------------------------------------------------------------------

_apt_update_list() {
    _info "تحديث قائمة الحزم (apt)..."
    _log "INFO" "apt update -- بدء"
    if (( SAHEL_DRY_RUN )); then
        _dry "apt-get update"
        return 0
    fi
    if _as_root apt-get update -qq 2>&1 | tail -2; then
        _ok "تم تحديث قائمة الحزم"
        _log "INFO" "apt update -- نجح"
        return 0
    else
        _err "فشل تحديث قائمة الحزم"
        _log "ERROR" "apt update -- فشل"
        return 1
    fi
}

_apt_upgradable_count() {
    apt list --upgradable 2>/dev/null | grep -c 'upgradable' || echo "0"
}

_apt_show_upgradable() {
    local max="${1:-20}"
    apt list --upgradable 2>/dev/null | grep -v '^Listing' | head -"$max" | while IFS= read -r line; do
        echo -e "    ${C_DIM}- ${line}${C_RESET}"
    done
}

_apt_do_upgrade() {
    _info "جاري التحديث..."
    _log "INFO" "apt upgrade -- بدء"
    if (( SAHEL_DRY_RUN )); then
        _dry "apt-get upgrade -y"
        _log "INFO" "apt upgrade -- dry-run"
        return 0
    fi
    if DEBIAN_FRONTEND=noninteractive _as_root apt-get upgrade -y -qq 2>&1 | tail -3; then
        _ok "تم التحديث"
        _log "INFO" "apt upgrade -- نجح"
        return 0
    else
        _err "حدث خطأ اثناء التحديث"
        _log "ERROR" "apt upgrade -- فشل"
        return 1
    fi
}

_apt_orphan_count() {
    _as_root apt-get --dry-run autoremove 2>/dev/null | grep -c '^Remv ' || echo "0"
}

_apt_autoremove() {
    _log "INFO" "apt autoremove -- بدء"
    if (( SAHEL_DRY_RUN )); then
        _dry "apt-get autoremove -y"
        return 0
    fi
    if _as_root apt-get autoremove -y -qq 2>/dev/null; then
        _ok "تم حذف الحزم اليتيمة"
        _log "INFO" "apt autoremove -- نجح"
    else
        _err "فشل حذف الحزم اليتيمة"
        _log "ERROR" "apt autoremove -- فشل"
    fi
}

_apt_clean_cache() {
    _log "INFO" "apt clean -- بدء"
    if (( SAHEL_DRY_RUN )); then
        _dry "apt-get clean && apt-get autoclean"
        return 0
    fi
    _as_root apt-get clean -qq 2>/dev/null
    _as_root apt-get autoclean -qq 2>/dev/null
    _ok "تم تنظيف الكاش"
    _log "INFO" "apt clean -- نجح"
}

_apt_cache_size() {
    du -sb /var/cache/apt/archives/ 2>/dev/null | awk '{print $1}' || echo "0"
}

_apt_list_manual() {
    apt-mark showmanual 2>/dev/null | sort
}

_apt_search() {
    local term="$1"
    apt-cache search "$term" 2>/dev/null | head -20
}

_apt_show_pkg() {
    local pkg="$1"
    apt-cache show "$pkg" 2>/dev/null | grep -E '^(Package|Version|Installed-Size|Description)' | head -6
}

_apt_install() {
    local pkg="$1"
    _validate_pkg_name "$pkg" || return 1

    _log "INFO" "apt install ${pkg} -- بدء"
    if (( SAHEL_DRY_RUN )); then
        _dry "apt-get install -y ${pkg}"
        return 0
    fi
    if _as_root apt-get install -y "$pkg" 2>&1 | tail -5; then
        _ok "تم تثبيت ${pkg}"
        _log "INFO" "apt install ${pkg} -- نجح"
        return 0
    else
        _err "فشل تثبيت ${pkg}"
        _log "ERROR" "apt install ${pkg} -- فشل"
        return 1
    fi
}

_apt_remove() {
    local pkg="$1" purge="${2:-0}"
    _validate_pkg_name "$pkg" || return 1

    local action="remove"
    (( purge )) && action="purge"

    _log "INFO" "apt ${action} ${pkg} -- بدء"
    if (( SAHEL_DRY_RUN )); then
        _dry "apt-get ${action} -y ${pkg}"
        return 0
    fi
    if _as_root apt-get "$action" -y "$pkg" 2>&1 | tail -3; then
        _ok "تم حذف ${pkg} (apt ${action})"
        _log "INFO" "apt ${action} ${pkg} -- نجح"
        return 0
    else
        _err "فشل حذف ${pkg} (apt ${action})"
        _log "ERROR" "apt ${action} ${pkg} -- فشل"
        return 1
    fi
}

_apt_is_installed() {
    dpkg -l "$1" 2>/dev/null | grep -q '^ii'
}

_apt_removal_impact() {
    local pkg="$1"
    local output
    if ! output=$(_as_root apt-get --dry-run remove "$pkg" 2>&1); then
        _warn "تعذر حساب تأثير حذف ${pkg}"
        _log "WARN" "apt removal impact for ${pkg} -- فشل"
        return 1
    fi
    echo "$output" | grep '^Remv ' | awk '{print $2}'
    return 0
}

# ----------------------------------------------------------------------------
#  SECTION 07: snap
#  عمليات مدير الحزم snap
# ----------------------------------------------------------------------------

_snap_available() {
    _has_cmd snap
}

_snap_refresh() {
    _log "INFO" "snap refresh -- بدء"
    if (( SAHEL_DRY_RUN )); then
        _dry "snap refresh"
        return 0
    fi
    local output
    if output=$(_as_root snap refresh 2>&1); then
        if echo "$output" | grep -qi 'All snaps up to date'; then
            _ok "جميع حزم Snap محدثة"
        else
            _ok "تم تحديث حزم Snap"
            echo "$output" | head -5 | while IFS= read -r l; do
                echo -e "    ${C_DIM}${l}${C_RESET}"
            done
        fi
        _log "INFO" "snap refresh -- نجح"
    else
        _warn "فشل تحديث بعض حزم Snap"
        _log "WARN" "snap refresh -- فشل جزئي"
    fi
}

_snap_list() {
    snap list 2>/dev/null
}

_snap_is_installed() {
    snap list "$1" &>/dev/null
}

_snap_remove() {
    local pkg="$1"
    _log "INFO" "snap remove ${pkg} -- بدء"
    if (( SAHEL_DRY_RUN )); then
        _dry "snap remove ${pkg}"
        return 0
    fi
    if _as_root snap remove "$pkg" 2>&1 | tail -3; then
        _ok "تم حذف ${pkg} (snap)"
        _log "INFO" "snap remove ${pkg} -- نجح"
        return 0
    else
        _err "فشل حذف ${pkg} (snap)"
        _log "ERROR" "snap remove ${pkg} -- فشل"
        return 1
    fi
}

_snap_old_revisions_count() {
    snap list --all 2>/dev/null | awk '/disabled/' | wc -l || echo "0"
}

_snap_clean_old() {
    _log "INFO" "snap clean old -- بدء"
    if (( SAHEL_DRY_RUN )); then
        _dry "snap remove (old disabled revisions)"
        return 0
    fi
    snap list --all 2>/dev/null | awk '/disabled/{print $1, $3}' | while read -r sname srev; do
        _as_root snap remove "$sname" --revision="$srev" 2>/dev/null || true
    done
    _ok "تم حذف نسخ Snap القديمة"
    _log "INFO" "snap clean old -- نجح"
}

# ----------------------------------------------------------------------------
#  SECTION 08: flatpak
#  عمليات مدير الحزم flatpak
# ----------------------------------------------------------------------------

_flatpak_available() {
    _has_cmd flatpak
}

_flatpak_update() {
    _log "INFO" "flatpak update -- بدء"
    if (( SAHEL_DRY_RUN )); then
        _dry "flatpak update -y"
        return 0
    fi
    if _as_root flatpak update -y --noninteractive 2>&1 | tail -3; then
        _ok "تم تحديث حزم Flatpak"
        _log "INFO" "flatpak update -- نجح"
    else
        _warn "فشل تحديث بعض حزم Flatpak"
        _log "WARN" "flatpak update -- فشل جزئي"
    fi
}

_flatpak_list_apps() {
    flatpak list --app 2>/dev/null
}

_flatpak_is_installed() {
    flatpak list --app 2>/dev/null | grep -qi "$1"
}

_flatpak_remove() {
    local pkg="$1"
    _log "INFO" "flatpak remove ${pkg} -- بدء"
    if (( SAHEL_DRY_RUN )); then
        _dry "flatpak uninstall -y ${pkg}"
        return 0
    fi
    if _as_root flatpak uninstall -y "$pkg" 2>&1 | tail -3; then
        _ok "تم حذف ${pkg} (flatpak)"
        _log "INFO" "flatpak remove ${pkg} -- نجح"
        return 0
    else
        _err "فشل حذف ${pkg} (flatpak)"
        _log "ERROR" "flatpak remove ${pkg} -- فشل"
        return 1
    fi
}

