# ─────────────────────────────────────────────────────────────────────────────
show_menu() {
    printf "  ${C_BOLD}${C_WHITE}اختر العملية المطلوبة:${C_RESET}\n"
    echo ""
    printf "    ${C_GREEN}${C_BOLD}1${C_RESET}  ${SYM_SHIELD}  صيانة آمنة ${C_DIM}(تحديث + ترقية + تنظيف)${C_RESET}\n"
    printf "    ${C_BLUE}${C_BOLD}2${C_RESET}  ${SYM_INFO}  معاينة قبل التنفيذ ${C_DIM}(Dry Run)${C_RESET}\n"
    printf "    ${C_RED}${C_BOLD}3${C_RESET}  ${SYM_ROCKET}  صيانة متقدمة ${C_DIM}(dist-upgrade — تحذير!)${C_RESET}\n"
    printf "    ${C_YELLOW}${C_BOLD}4${C_RESET}  ${SYM_BROOM}  تنظيف فقط\n"
    printf "    ${C_CYAN}${C_BOLD}5${C_RESET}  ${SYM_GEAR}  حالة النظام\n"
    printf "    ${C_MAGENTA}${C_BOLD}6${C_RESET}  ${SYM_BULLET}  حول الأداة\n"
    printf "    ${C_GRAY}${C_BOLD}0${C_RESET}  ${SYM_ARROW}  خروج${C_RESET}\n"
    echo ""
    printf "  ${C_BOLD}${SYM_ARROW} اختيارك: ${C_RESET}"
}

interactive_loop() {
    INTERACTIVE_MODE=true
    while true; do
        print_banner
        show_menu
        local choice
        read -r choice

        # إعادة تهيئة العدّادات لكل عملية جديدة
        reset_counters

        case "${choice}" in
            1) mode_safe || true ;;
            2) mode_preview || true ;;
            3) mode_advanced || true ;;
            4) mode_cleanup_only || true ;;
            5) mode_system_status || true ;;
            6) mode_about || true ;;
            0|q|Q|خروج)
                echo ""
                msg_info "شكرًا لاستخدامك ${SCRIPT_NAME}"
                exit 0
                ;;
            *)
                msg_warn "اختيار غير صالح: ${choice}"
                ;;
        esac
        echo ""
        printf "  ${C_DIM}اضغط Enter للعودة إلى القائمة...${C_RESET}"
        read -r
    done
}

# ─────────────────────────────────────────────────────────────────────────────
# واجهة CLI (غير تفاعلية)
# ─────────────────────────────────────────────────────────────────────────────
usage() {
    cat << EOF
${SCRIPT_NAME} v${SCRIPT_VERSION} — أداة صيانة وتحديث أوبنتو سطح المكتب
${SCRIPT_AUTHOR} — ${SCRIPT_URL}

الاستخدام:
  ${SCRIPT_NAME} [خيار]

الخيارات:
  --safe          الصيانة الآمنة (الوضع الافتراضي)
  --preview       معاينة بدون تنفيذ (Dry Run)
  --advanced      صيانة متقدمة (dist-upgrade)
  --cleanup       تنظيف فقط
  --status        عرض حالة النظام
  --about         حول الأداة
  --help, -h      عرض هذه المساعدة
  (بدون خيارات)   القائمة التفاعلية

أمثلة:
  sudo ${SCRIPT_NAME} --safe
  sudo ${SCRIPT_NAME} --preview
  sudo ${SCRIPT_NAME}              # القائمة التفاعلية
EOF
}

# ─────────────────────────────────────────────────────────────────────────────
# نقطة الدخول الرئيسية
# ─────────────────────────────────────────────────────────────────────────────
main() {
    setup_colors
    setup_symbols
    init_logging

    # --help و --about لا تحتاج root
    case "${1:-}" in
        --help|-h)
            usage
            exit 0
            ;;
        --about)
            mode_about
            exit 0
            ;;
        --status)
            mode_system_status
            exit 0
            ;;
    esac

    # التحقق من صلاحيات root لبقية الأوضاع
    ensure_root "$@"

    # إعادة تهيئة الألوان والتسجيل بعد sudo (قد يتغير TERM)
    setup_colors
    setup_symbols
    init_logging

    case "${1:-}" in
        --safe)
            mode_safe
            ;;
        --preview)
            mode_preview
            ;;
        --advanced)
            mode_advanced
            ;;
        --cleanup)
            mode_cleanup_only
            ;;
        "")
            # الوضع التفاعلي
            if [[ -t 0 ]]; then
                interactive_loop
            else
                # stdin ليس طرفية — تشغيل الوضع الآمن تلقائيًا
                log_info "تشغيل غير تفاعلي — الوضع الآمن الافتراضي"
                mode_safe
            fi
            ;;
        *)
            printf "خيار غير معروف: %s\n" "$1" >&2
            usage >&2
            exit 1
            ;;
    esac
}

main "$@"
