}

_pkg_list_flatpak() {
    _header
    _section "البرامج المثبتة (Flatpak)"

    if ! _flatpak_available; then
        _info "Flatpak غير مثبت"
        _pause
        return
    fi

    echo ""
    _flatpak_list_apps | while IFS= read -r line; do
        echo -e "    ${C_DIM}${line}${C_RESET}"
