IFS=$'\n\t'

# ─────────────────────────────────────────────────────────────────────────────
# الثوابت العامة
# ─────────────────────────────────────────────────────────────────────────────
readonly SCRIPT_NAME="ubuntu-maintain"
readonly SCRIPT_VERSION="2.0.0"
readonly SCRIPT_DATE="2026-03-25"
readonly SCRIPT_AUTHOR="Fahad Alsharari"
readonly SCRIPT_URL="https://fahadalsharari.sa"

readonly MIN_DISK_MB=500          # الحد الأدنى للمساحة الحرة (ميغابايت)
readonly LOCK_WAIT_SEC=120        # مهلة انتظار تحرير قفل apt (ثانية)
readonly CONNECTIVITY_TIMEOUT=5   # مهلة فحص الاتصال (ثوانٍ)
readonly SUDO_KEEPALIVE_SEC=60    # تجديد sudo كل 60 ثانية

# مسارات التسجيل
LOG_DIR="/var/log/${SCRIPT_NAME}"
LOG_FILE="${LOG_DIR}/${SCRIPT_NAME}-$(date +%Y%m%d-%H%M%S).log"

# متغير للتحكم في الوضع التفاعلي
INTERACTIVE_MODE=false

# ─────────────────────────────────────────────────────────────────────────────
# عدّادات التقرير النهائي
# ─────────────────────────────────────────────────────────────────────────────
declare -i COUNT_SUCCESS=0
declare -i COUNT_SKIPPED=0
declare -i COUNT_FAILED=0
declare -i COUNT_WARNINGS=0
declare -a SUMMARY_LINES=()
declare -a WARNING_LINES=()
declare -a ERROR_LINES=()

# حالة كل نظام حزم
APT_STATUS="—"
SNAP_STATUS="—"
FLATPAK_STATUS="—"
CLEANUP_STATUS="—"
REBOOT_RECOMMENDED="لا"

# ─────────────────────────────────────────────────────────────────────────────
# الألوان والتنسيق — مع fallback لبيئات بدون ألوان
# ─────────────────────────────────────────────────────────────────────────────
_COLORS_INIT=""
C_RESET="" C_BOLD="" C_DIM="" C_RED="" C_GREEN=""
C_YELLOW="" C_BLUE="" C_MAGENTA="" C_CYAN="" C_WHITE="" C_GRAY=""
C_BG_RED="" C_BG_GREEN="" C_BG_BLUE=""
HAS_COLOR=false

setup_colors() {
    [[ -n "${_COLORS_INIT}" ]] && return 0
    _COLORS_INIT=1
    if [[ -t 1 ]] && [[ "${TERM:-dumb}" != "dumb" ]] && command -v tput &>/dev/null && tput colors &>/dev/null && (( $(tput colors) >= 8 )); then
        C_RESET=$'\033[0m'
        C_BOLD=$'\033[1m'
        C_DIM=$'\033[2m'
        C_RED=$'\033[1;31m'
        C_GREEN=$'\033[1;32m'
        C_YELLOW=$'\033[1;33m'
        C_BLUE=$'\033[1;34m'
        C_MAGENTA=$'\033[1;35m'
        C_CYAN=$'\033[1;36m'
        C_WHITE=$'\033[1;37m'
        C_GRAY=$'\033[0;90m'
        C_BG_RED=$'\033[41m'
        C_BG_GREEN=$'\033[42m'
        C_BG_BLUE=$'\033[44m'
        HAS_COLOR=true
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# رموز Unicode — مع fallback لـ ASCII
# ─────────────────────────────────────────────────────────────────────────────
_SYMBOLS_INIT=""
SYM_OK="[OK]" SYM_FAIL="[X]" SYM_WARN="[!]" SYM_INFO="[i]"
SYM_ARROW="<-" SYM_BULLET="*" SYM_GEAR="[G]" SYM_SHIELD="[S]"
SYM_BROOM="[C]" SYM_ROCKET="[R]"
SYM_BOX_H="-" SYM_BOX_V="|" SYM_BOX_TL="+" SYM_BOX_TR="+"
SYM_BOX_BL="+" SYM_BOX_BR="+"
SYM_SPINNER_FRAMES=("-" "\\" "|" "/")

setup_symbols() {
    [[ -n "${_SYMBOLS_INIT}" ]] && return 0
    _SYMBOLS_INIT=1
    if [[ "${LANG:-}" == *UTF-8* ]] || [[ "${LC_ALL:-}" == *UTF-8* ]] || [[ "${LC_CTYPE:-}" == *UTF-8* ]]; then
        SYM_OK="✔"
        SYM_FAIL="✘"
        SYM_WARN="⚠"
        SYM_INFO="ℹ"
        SYM_ARROW="←"
        SYM_BULLET="●"
        SYM_GEAR="⚙"
        SYM_SHIELD="🛡"
        SYM_BROOM="🧹"
        SYM_ROCKET="🚀"
        SYM_BOX_H="─"
        SYM_BOX_V="│"
        SYM_BOX_TL="┌"
        SYM_BOX_TR="┐"
        SYM_BOX_BL="└"
        SYM_BOX_BR="┘"
        SYM_SPINNER_FRAMES=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# التسجيل (Logging)
# ─────────────────────────────────────────────────────────────────────────────
_log_target=""

init_logging() {
    # محاولة إنشاء مجلد التسجيل الأساسي
    if mkdir -p "${LOG_DIR}" 2>/dev/null && [[ -w "${LOG_DIR}" ]]; then
        touch "${LOG_FILE}" 2>/dev/null || true
        _log_target="${LOG_FILE}"
    else
        # fallback: /tmp
        local fallback_dir="/tmp/${SCRIPT_NAME}-logs"
        mkdir -p "${fallback_dir}" 2>/dev/null || true
        LOG_DIR="${fallback_dir}"
        LOG_FILE="${fallback_dir}/${SCRIPT_NAME}-$(date +%Y%m%d-%H%M%S).log"
        touch "${LOG_FILE}" 2>/dev/null || true
        _log_target="${LOG_FILE}"
    fi
    log_raw "═══ بدء التشغيل: ${SCRIPT_NAME} v${SCRIPT_VERSION} — $(date '+%Y-%m-%d %H:%M:%S %Z') ═══"
}

log_raw() {
    [[ -n "${_log_target}" ]] && printf '%s\n' "$*" >> "${_log_target}" 2>/dev/null || true
}

log_entry() {
    local level="$1"; shift
    local ts
    ts="$(date '+%Y-%m-%d %H:%M:%S')"
    log_raw "[${ts}] [${level}] $*"
}

log_info()    { log_entry "INFO"    "$@"; }
log_success() { log_entry "SUCCESS" "$@"; }
log_warn()    { log_entry "WARN"    "$@"; WARNING_LINES+=("$*"); (( COUNT_WARNINGS++ )) || true; }
log_error()   { log_entry "ERROR"   "$@"; ERROR_LINES+=("$*"); }
log_skip()    { log_entry "SKIP"    "$@"; (( COUNT_SKIPPED++ )) || true; }
log_cmd()     { log_entry "CMD"     "$@"; }

# ─────────────────────────────────────────────────────────────────────────────
# دوال الطباعة المنسقة
# ─────────────────────────────────────────────────────────────────────────────
_repeat_char() {
    local char="$1" count="$2" i
    for ((i=0; i<count; i++)); do printf '%s' "${char}"; done
}

print_line() {
    local width=${1:-70}
    local ch="${2:-${SYM_BOX_H}}"
    printf "${C_GRAY}"
    _repeat_char "${ch}" "${width}"
    printf "${C_RESET}\n"
}

print_header_box() {
    local text="$1"
    local width=70
    echo ""
    printf "${C_CYAN}${SYM_BOX_TL}"
    _repeat_char "${SYM_BOX_H}" "$((width - 2))"
    printf "${SYM_BOX_TR}${C_RESET}\n"
    printf "${C_CYAN}${SYM_BOX_V}${C_RESET}  ${C_BOLD}${C_WHITE}%s${C_RESET}" "${text}"
    local text_len=${#text}
    local padding=$((width - 4 - text_len))
    if (( padding > 0 )); then
        printf '%*s' "${padding}" ''
    fi
    printf "${C_CYAN}${SYM_BOX_V}${C_RESET}\n"
    printf "${C_CYAN}${SYM_BOX_BL}"
    _repeat_char "${SYM_BOX_H}" "$((width - 2))"
    printf "${SYM_BOX_BR}${C_RESET}\n"
}

msg_ok()   { printf "  ${C_GREEN}${SYM_OK}${C_RESET}  %s\n" "$*"; log_success "$*"; }
msg_fail() { printf "  ${C_RED}${SYM_FAIL}${C_RESET}  %s\n" "$*"; log_error "$*"; }
msg_warn() { printf "  ${C_YELLOW}${SYM_WARN}${C_RESET}  %s\n" "$*"; log_warn "$*"; }
msg_info() { printf "  ${C_BLUE}${SYM_INFO}${C_RESET}  %s\n" "$*"; log_info "$*"; }
msg_step() { printf "\n  ${C_MAGENTA}${SYM_GEAR}${C_RESET}  ${C_BOLD}%s${C_RESET}\n" "$*"; log_info "خطوة: $*"; }

# مؤشر تقدم بسيط (spinner) — يُشغَّل في الخلفية
_spinner_pid=""
start_spinner() {
    local msg="${1:-جارٍ التنفيذ...}"
    if [[ ! -t 1 ]]; then return 0; fi
    (
        local i=0
        local frames_count=${#SYM_SPINNER_FRAMES[@]}
        while true; do
            printf "\r  ${C_CYAN}%s${C_RESET}  %s " "${SYM_SPINNER_FRAMES[$((i % frames_count))]}" "${msg}"
            sleep 0.12
            (( i++ )) || true
        done
    ) &
    _spinner_pid=$!
    disown "${_spinner_pid}" 2>/dev/null || true
}

stop_spinner() {
    if [[ -n "${_spinner_pid}" ]]; then
        kill "${_spinner_pid}" 2>/dev/null || true
        wait "${_spinner_pid}" 2>/dev/null || true
        _spinner_pid=""
        printf "\r%*s\r" 80 ""   # مسح السطر
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# معالجة الإشارات والأخطاء (Trap Handlers)
# ─────────────────────────────────────────────────────────────────────────────
cleanup_on_exit() {
    stop_spinner
    stop_sudo_keepalive
    if [[ -f "${LOG_FILE}" ]] && [[ -s "${LOG_FILE}" ]]; then
        printf "\n  ${C_GRAY}${SYM_INFO} السجل: ${LOG_FILE}${C_RESET}\n"
    fi
}

on_interrupt() {
    stop_spinner
    printf "\n\n  ${C_YELLOW}${SYM_WARN} تم إلغاء التنفيذ بواسطة المستخدم (Ctrl+C)${C_RESET}\n"
    log_warn "إلغاء بواسطة المستخدم (SIGINT/SIGTERM)"
    exit 130
}

trap 'on_interrupt' INT TERM
trap 'cleanup_on_exit' EXIT

# ─────────────────────────────────────────────────────────────────────────────
# تجديد صلاحيات sudo بشكل دوري لتجنب انتهاء الصلاحية أثناء التحديث
# ─────────────────────────────────────────────────────────────────────────────
_sudo_keepalive_pid=""

start_sudo_keepalive() {
    (
        while true; do
            sudo -n true 2>/dev/null || true
            sleep "${SUDO_KEEPALIVE_SEC}"
        done
    ) &
    _sudo_keepalive_pid=$!
    disown "${_sudo_keepalive_pid}" 2>/dev/null || true
}

stop_sudo_keepalive() {
    if [[ -n "${_sudo_keepalive_pid}" ]]; then
        kill "${_sudo_keepalive_pid}" 2>/dev/null || true
        wait "${_sudo_keepalive_pid}" 2>/dev/null || true
        _sudo_keepalive_pid=""
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# فحوصات ما قبل التشغيل (Pre-flight Checks)
# ─────────────────────────────────────────────────────────────────────────────

# إعادة تشغيل بـ sudo إذا لم نكن root
ensure_root() {
    if [[ "${EUID}" -ne 0 ]]; then
        msg_info "يتطلب صلاحيات المسؤول — سيُطلب منك إدخال كلمة المرور..."
        exec sudo --preserve-env=TERM,LANG,LC_ALL,LC_CTYPE,HOME bash "$0" "$@"
    fi
}

check_ubuntu() {
    if [[ ! -f /etc/os-release ]]; then
        msg_fail "لم يُعثر على /etc/os-release — هذه الأداة مخصصة لأوبنتو"
        return 1
    fi
    # shellcheck source=/dev/null
    source /etc/os-release
    if [[ "${ID:-}" != "ubuntu" ]]; then
        msg_fail "نظام التشغيل (${ID:-غير معروف}) غير مدعوم — مطلوب Ubuntu"
        return 1
    fi
    msg_ok "نظام التشغيل: Ubuntu ${VERSION_ID:-} (${VERSION_CODENAME:-})"
    log_info "Ubuntu ${VERSION_ID:-} — ${PRETTY_NAME:-}"
    return 0
}

check_bash_version() {
    if (( BASH_VERSINFO[0] < 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 4) )); then
        msg_fail "يتطلب Bash 4.4 أو أحدث — الإصدار الحالي: ${BASH_VERSION}"
        return 1
    fi
    return 0
}

check_connectivity() {
    local hosts=("archive.ubuntu.com" "security.ubuntu.com" "1.1.1.1")
    for host in "${hosts[@]}"; do
        if ping -c1 -W "${CONNECTIVITY_TIMEOUT}" "${host}" &>/dev/null; then
            msg_ok "اتصال الإنترنت متاح"
            log_info "فحص الاتصال نجح عبر ${host}"
            return 0
        fi
    done
    # محاولة أخيرة عبر curl
    if curl -sf --max-time "${CONNECTIVITY_TIMEOUT}" "https://archive.ubuntu.com" &>/dev/null; then
        msg_ok "اتصال الإنترنت متاح (عبر HTTPS)"
        return 0
    fi
    msg_fail "لا يوجد اتصال بالإنترنت — لا يمكن متابعة التحديث"
    return 1
}

check_disk_space() {
    local avail_kb
    avail_kb=$(df --output=avail / 2>/dev/null | tail -1 | tr -d ' ')
    if [[ -z "${avail_kb}" ]]; then
        msg_warn "تعذر قراءة معلومات المساحة"
        return 0
    fi
    local avail_mb=$(( avail_kb / 1024 ))
    if (( avail_mb < MIN_DISK_MB )); then
        msg_fail "المساحة المتاحة (${avail_mb} MB) أقل من الحد الأدنى (${MIN_DISK_MB} MB)"
        return 1
    fi
    msg_ok "المساحة المتاحة: ${avail_mb} MB"
    return 0
}

check_apt_lock() {
    local lock_files=(
        /var/lib/dpkg/lock-frontend
        /var/lib/dpkg/lock
        /var/lib/apt/lists/lock
        /var/cache/apt/archives/lock
    )
    local waited=0
    while (( waited < LOCK_WAIT_SEC )); do
        local locked=false
        for lf in "${lock_files[@]}"; do
            if [[ -f "${lf}" ]] && fuser "${lf}" &>/dev/null; then
                locked=true
                break
            fi
        done
        if [[ "${locked}" == false ]]; then
            msg_ok "لا يوجد قفل على apt/dpkg"
            return 0
        fi
        if (( waited == 0 )); then
            msg_warn "يوجد قفل على apt/dpkg — بانتظار تحرّره (حتى ${LOCK_WAIT_SEC} ثانية)..."
        fi
        sleep 5
        (( waited += 5 )) || true
    done
    msg_fail "لم يتحرر قفل apt/dpkg خلال ${LOCK_WAIT_SEC} ثانية"
    return 1
}

# إصلاح أي حالة dpkg مكسورة قبل البدء
try_fix_dpkg() {
    if ! dpkg --audit &>/dev/null; then
        msg_warn "اكتُشفت حالة dpkg غير مكتملة — محاولة إصلاح..."
        log_cmd "dpkg --configure -a"
        if dpkg --configure -a >> "${LOG_FILE}" 2>&1; then
            msg_ok "تم إصلاح dpkg"
        else
            msg_fail "فشل إصلاح dpkg — قد يحتاج تدخلاً يدويًا"
            return 1
        fi
    fi
    return 0
}

# run_preflight يقبل معامل اختياري --skip-connectivity لتخطي فحص الاتصال
run_preflight() {
    local skip_connectivity=false
    if [[ "${1:-}" == "--skip-connectivity" ]]; then
        skip_connectivity=true
    fi

    print_header_box "فحوصات ما قبل التشغيل"

    if ! check_bash_version; then
        return 1
    fi

    if ! check_ubuntu; then
        return 1
    fi

    if ! check_disk_space; then
        log_error "فحص المساحة فشل"
        return 1
    fi

    if [[ "${skip_connectivity}" == false ]]; then
        if ! check_connectivity; then
            log_error "لا يوجد اتصال"
            return 1
        fi
    else
        msg_info "تم تخطي فحص الاتصال (غير مطلوب لهذه العملية)"
    fi

    if ! check_apt_lock; then
        log_error "قفل apt لم يتحرر"
        return 1
    fi

    if ! try_fix_dpkg; then
        log_error "dpkg مكسور"
        return 1
    fi

    echo ""
    msg_ok "جميع الفحوصات ناجحة — يمكن المتابعة"
    start_sudo_keepalive
    return 0
}

# ─────────────────────────────────────────────────────────────────────────────
# تنفيذ أمر مع تسجيل وإدارة حالة
# ─────────────────────────────────────────────────────────────────────────────
run_logged() {
    local desc="$1"; shift
    log_cmd "$*"
    local output rc=0
    output=$("$@" 2>&1) || rc=$?
    if [[ -n "${output}" ]]; then
        echo "${output}" | head -200 >> "${LOG_FILE}" 2>/dev/null || true
    fi
    if (( rc == 0 )); then
        msg_ok "${desc}"
        (( COUNT_SUCCESS++ )) || true
        SUMMARY_LINES+=("${SYM_OK} ${desc}")
    else
        msg_fail "${desc} (كود: ${rc})"
        (( COUNT_FAILED++ )) || true
        SUMMARY_LINES+=("${SYM_FAIL} ${desc} — كود: ${rc}")
        ERROR_LINES+=("${desc} — كود الخروج: ${rc}")
    fi
    return "${rc}"
}

# ─────────────────────────────────────────────────────────────────────────────
# عمليات apt
# ─────────────────────────────────────────────────────────────────────────────
do_apt_update() {
    msg_step "تحديث قائمة الحزم (apt-get update)"
    start_spinner "جارٍ تحديث القوائم..."
    local output rc=0
    log_cmd "apt-get update"
    output=$(apt-get update 2>&1) || rc=$?
    stop_spinner
    echo "${output}" | head -100 >> "${LOG_FILE}" 2>/dev/null || true
    if (( rc == 0 )); then
        msg_ok "تم تحديث قائمة الحزم"
        (( COUNT_SUCCESS++ )) || true
    else
        msg_fail "فشل تحديث القائمة (كود: ${rc})"
        (( COUNT_FAILED++ )) || true
        APT_STATUS="فشل التحديث"
        return "${rc}"
    fi
    return 0
}

do_apt_upgrade() {
    msg_step "ترقية الحزم (apt-get upgrade)"
    local sim_output
    sim_output=$(apt-get --simulate upgrade 2>&1) || true
    local upgradable
    upgradable=$(echo "${sim_output}" | grep -c "^Inst " || true)
    if (( upgradable == 0 )); then
        msg_ok "لا توجد حزم تحتاج ترقية"
        APT_STATUS="لا يوجد تحديثات"
        (( COUNT_SUCCESS++ )) || true
        SUMMARY_LINES+=("${SYM_OK} لا توجد حزم للترقية")
        return 0
    fi
    msg_info "عدد الحزم المرشحة للترقية: ${upgradable}"
    start_spinner "جارٍ ترقية الحزم..."
    local rc=0
    DEBIAN_FRONTEND=noninteractive apt-get upgrade -y \
        -o Dpkg::Options::="--force-confdef" \
        -o Dpkg::Options::="--force-confold" \
        >> "${LOG_FILE}" 2>&1 || rc=$?
    stop_spinner
    if (( rc == 0 )); then
        msg_ok "تمت ترقية ${upgradable} حزمة بنجاح"
        APT_STATUS="نجاح (${upgradable} حزمة)"
        (( COUNT_SUCCESS++ )) || true
        SUMMARY_LINES+=("${SYM_OK} ترقية apt: ${upgradable} حزمة")
    else
        msg_fail "فشل في ترقية بعض الحزم (كود: ${rc})"
        APT_STATUS="فشل جزئي"
        (( COUNT_FAILED++ )) || true
        SUMMARY_LINES+=("${SYM_FAIL} ترقية apt فشلت جزئيًا")
    fi
    return "${rc}"
}

do_apt_full_upgrade() {
    msg_step "ترقية كاملة (apt-get dist-upgrade) — وضع متقدم"
    local sim_output
    sim_output=$(apt-get --simulate dist-upgrade 2>&1) || true
    local to_remove to_install
    to_remove=$(echo "${sim_output}" | grep -c "^Remv " || true)
    to_install=$(echo "${sim_output}" | grep -c "^Inst " || true)

    msg_info "ستُثبَّت: ${to_install} — ستُزال: ${to_remove}"

    if (( to_remove > 0 )); then
        msg_warn "ستتم إزالة ${to_remove} حزمة — تأكد من مراجعة القائمة"
        echo "${sim_output}" | grep "^Remv " | head -20
        printf "\n"
    fi

    start_spinner "جارٍ تنفيذ الترقية الكاملة..."
    local rc=0
    DEBIAN_FRONTEND=noninteractive apt-get dist-upgrade -y \
        -o Dpkg::Options::="--force-confdef" \
        -o Dpkg::Options::="--force-confold" \
        >> "${LOG_FILE}" 2>&1 || rc=$?
    stop_spinner

    if (( rc == 0 )); then
        msg_ok "اكتملت الترقية الكاملة"
        APT_STATUS="نجاح — ترقية كاملة"
        (( COUNT_SUCCESS++ )) || true
    else
        msg_fail "فشل في الترقية الكاملة (كود: ${rc})"
        APT_STATUS="فشل الترقية الكاملة"
        (( COUNT_FAILED++ )) || true
    fi
    return "${rc}"
}

# ─────────────────────────────────────────────────────────────────────────────
# عمليات snap
# ─────────────────────────────────────────────────────────────────────────────
do_snap_refresh() {
    if ! command -v snap &>/dev/null; then
        msg_info "snap غير مثبّت — تم التخطي"
        SNAP_STATUS="غير مثبّت"
        log_skip "snap غير مثبّت"
        SUMMARY_LINES+=("${SYM_INFO} snap: غير مثبّت — تم التخطي")
        return 0
    fi
    msg_step "تحديث حزم snap"
    start_spinner "جارٍ تحديث snap..."
    local output rc=0
    log_cmd "snap refresh"
    output=$(snap refresh 2>&1) || rc=$?
    stop_spinner
    echo "${output}" | head -50 >> "${LOG_FILE}" 2>/dev/null || true

    if (( rc == 0 )); then
        if echo "${output}" | grep -qi "All snaps up to date"; then
            msg_ok "جميع حزم snap محدّثة"
            SNAP_STATUS="لا يوجد تحديثات"
        else
            msg_ok "تم تحديث حزم snap"
            SNAP_STATUS="نجاح"
        fi
        (( COUNT_SUCCESS++ )) || true
    else
        if echo "${output}" | grep -qi "has running apps\|pending\|snap changes"; then
            msg_warn "بعض حزم snap لا يمكن تحديثها الآن (قيد الاستخدام أو معلّقة)"
            SNAP_STATUS="تحديث جزئي"
        else
            msg_fail "فشل تحديث snap (كود: ${rc})"
            SNAP_STATUS="فشل"
            (( COUNT_FAILED++ )) || true
        fi
    fi
    SUMMARY_LINES+=("${SYM_BULLET} snap: ${SNAP_STATUS}")
    return 0
}

# ─────────────────────────────────────────────────────────────────────────────
# عمليات flatpak
# ─────────────────────────────────────────────────────────────────────────────
do_flatpak_update() {
    if ! command -v flatpak &>/dev/null; then
        msg_info "flatpak غير مثبّت — تم التخطي"
        FLATPAK_STATUS="غير مثبّت"
        log_skip "flatpak غير مثبّت"
        SUMMARY_LINES+=("${SYM_INFO} flatpak: غير مثبّت — تم التخطي")
        return 0
    fi
    msg_step "تحديث حزم flatpak"
    start_spinner "جارٍ تحديث flatpak..."
    local rc=0
    log_cmd "flatpak update -y --noninteractive"
    flatpak update -y --noninteractive >> "${LOG_FILE}" 2>&1 || rc=$?
    stop_spinner

    if (( rc == 0 )); then
        msg_ok "تم تحديث flatpak"
        FLATPAK_STATUS="نجاح"
        (( COUNT_SUCCESS++ )) || true
    else
        msg_fail "فشل تحديث flatpak (كود: ${rc})"
        FLATPAK_STATUS="فشل"
        (( COUNT_FAILED++ )) || true
    fi
    SUMMARY_LINES+=("${SYM_BULLET} flatpak: ${FLATPAK_STATUS}")
    return 0
}

# ─────────────────────────────────────────────────────────────────────────────
# التنظيف — محسّن مع عرض المساحة المستردة
# ─────────────────────────────────────────────────────────────────────────────
get_disk_free_mb() {
    local avail_kb
    avail_kb=$(df --output=avail / 2>/dev/null | tail -1 | tr -d ' ')
    echo $(( avail_kb / 1024 ))
}

do_cleanup() {
    msg_step "تنظيف الحزم والمخابئ"

    # قياس المساحة قبل التنظيف
    local before_mb
    before_mb=$(get_disk_free_mb)

    local all_ok=true

    # 1. إزالة الحزم غير المطلوبة
    msg_info "إزالة الحزم غير المطلوبة (autoremove)..."
    log_cmd "apt-get autoremove -y"
    if apt-get autoremove -y >> "${LOG_FILE}" 2>&1; then
        msg_ok "تم حذف الحزم غير المطلوبة"
    else
        msg_warn "فشل حذف بعض الحزم غير المطلوبة"
        all_ok=false
    fi

    # 2. تنظيف ذاكرة التخزين المؤقت لـ apt
    msg_info "تنظيف ذاكرة التخزين المؤقت (autoclean)..."
    log_cmd "apt-get autoclean"
    if apt-get autoclean >> "${LOG_FILE}" 2>&1; then
        msg_ok "تم تنظيف ذاكرة التخزين المؤقت"
    else
        msg_warn "فشل تنظيف ذاكرة التخزين المؤقت"
        all_ok=false
    fi

    # 3. حذف ملفات .deb القديمة من الكاش
    msg_info "حذف ملفات .deb القديمة من الكاش..."
    log_cmd "apt-get clean"
    if apt-get clean >> "${LOG_FILE}" 2>&1; then
        msg_ok "تم حذف ملفات .deb المخزّنة"
    else
        msg_warn "فشل حذف ملفات .deb"
        all_ok=false
    fi

    # 4. تنظيف النواة القديمة (الاحتفاظ بالحالية والسابقة فقط)
    local current_kernel
    current_kernel=$(uname -r)
    local old_kernels
    old_kernels=$(dpkg -l 'linux-image-*' 2>/dev/null | awk '/^ii/{print $2}' | grep -v "${current_kernel}" | grep -v 'linux-image-generic' || true)
    if [[ -n "${old_kernels}" ]]; then
        local kernel_count
        kernel_count=$(echo "${old_kernels}" | wc -l)
        if (( kernel_count > 1 )); then
            # نحتفظ بآخر نواة قديمة كاحتياط
            local kernels_to_remove
            kernels_to_remove=$(echo "${old_kernels}" | head -n -1)
            if [[ -n "${kernels_to_remove}" ]]; then
                local remove_count
                remove_count=$(echo "${kernels_to_remove}" | wc -l)
                msg_info "إزالة ${remove_count} نواة قديمة (مع الاحتفاظ بنسخة احتياطية)..."
                # shellcheck disable=SC2086
                if DEBIAN_FRONTEND=noninteractive apt-get purge -y ${kernels_to_remove} >> "${LOG_FILE}" 2>&1; then
                    msg_ok "تم إزالة النوى القديمة"
                else
                    msg_warn "فشل إزالة بعض النوى القديمة"
                    all_ok=false
                fi
            fi
        else
            msg_info "لا توجد نوى قديمة زائدة للإزالة"
        fi
    else
        msg_info "لا توجد نوى قديمة للإزالة"
    fi

    # 5. تنظيف سجلات systemd القديمة (الاحتفاظ بآخر 3 أيام)
    if command -v journalctl &>/dev/null; then
        msg_info "تنظيف سجلات systemd القديمة..."
        log_cmd "journalctl --vacuum-time=3d"
        if journalctl --vacuum-time=3d >> "${LOG_FILE}" 2>&1; then
            msg_ok "تم تنظيف السجلات القديمة"
        else
            msg_warn "فشل تنظيف السجلات"
            all_ok=false
        fi
    fi

    # 6. تنظيف المصغّرات (thumbnails) القديمة
    local thumb_dir="${HOME}/.cache/thumbnails"
    # عند تشغيل كـ root عبر sudo، HOME قد يكون /root
    # نحاول المسار الأصلي للمستخدم
    local real_user_home
    if [[ -n "${SUDO_USER:-}" ]]; then
        real_user_home=$(getent passwd "${SUDO_USER}" | cut -d: -f6 2>/dev/null || echo "")
        thumb_dir="${real_user_home}/.cache/thumbnails"
    fi
    if [[ -d "${thumb_dir}" ]]; then
        local thumb_size
        thumb_size=$(du -sm "${thumb_dir}" 2>/dev/null | awk '{print $1}' || echo "0")
        if (( thumb_size > 10 )); then
            msg_info "تنظيف المصغّرات القديمة (${thumb_size} MB)..."
            find "${thumb_dir}" -type f -atime +30 -delete 2>/dev/null || true
            msg_ok "تم تنظيف المصغّرات القديمة"
        fi
    fi

    # 7. تنظيف ملفات المؤقتة في /tmp القديمة (أكبر من 7 أيام)
    local tmp_count
    tmp_count=$(find /tmp -maxdepth 1 -type f -atime +7 2>/dev/null | wc -l || echo "0")
    if (( tmp_count > 0 )); then
        msg_info "تنظيف ${tmp_count} ملف مؤقت قديم من /tmp..."
        find /tmp -maxdepth 1 -type f -atime +7 -delete 2>/dev/null || true
        msg_ok "تم تنظيف الملفات المؤقتة"
    fi

    # حساب المساحة المستردة
    local after_mb
    after_mb=$(get_disk_free_mb)
    local saved_mb=$(( after_mb - before_mb ))

    echo ""
    if (( saved_mb > 0 )); then
        printf "  ${C_GREEN}${C_BOLD}${SYM_OK} المساحة المستردة: ${saved_mb} MB${C_RESET}\n"
        log_info "المساحة المستردة: ${saved_mb} MB"
    else
        printf "  ${C_DIM}${SYM_INFO} لم يتم استرداد مساحة إضافية ملحوظة${C_RESET}\n"
    fi

    if [[ "${all_ok}" == true ]]; then
        msg_ok "اكتمل التنظيف بنجاح"
        CLEANUP_STATUS="نجاح"
        (( COUNT_SUCCESS++ )) || true
    else
        msg_warn "اكتمل التنظيف مع بعض التحذيرات"
        CLEANUP_STATUS="جزئي"
    fi
    SUMMARY_LINES+=("${SYM_BULLET} التنظيف: ${CLEANUP_STATUS}")
    return 0
}

# ─────────────────────────────────────────────────────────────────────────────
# فحص إعادة التشغيل
# ─────────────────────────────────────────────────────────────────────────────
check_reboot_needed() {
    if [[ -f /var/run/reboot-required ]]; then
        REBOOT_RECOMMENDED="نعم"
        msg_warn "يُوصى بإعادة تشغيل الجهاز لتطبيق التحديثات"
        if [[ -f /var/run/reboot-required.pkgs ]]; then
            msg_info "الحزم التي تطلب إعادة التشغيل:"
            head -10 /var/run/reboot-required.pkgs | while IFS= read -r pkg; do
                printf "    ${C_DIM}%s${C_RESET}\n" "${pkg}"
            done
        fi
    else
        msg_ok "لا حاجة لإعادة تشغيل الجهاز"
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# الملخص النهائي
# ─────────────────────────────────────────────────────────────────────────────
print_summary() {
    echo ""
    print_header_box "الملخص النهائي"
    echo ""
    printf "  ${C_BOLD}${C_WHITE}%-24s${C_RESET} %s\n" "عمليات ناجحة:" "${C_GREEN}${COUNT_SUCCESS}${C_RESET}"
    printf "  ${C_BOLD}${C_WHITE}%-24s${C_RESET} %s\n" "تم تخطيها:" "${C_YELLOW}${COUNT_SKIPPED}${C_RESET}"
    printf "  ${C_BOLD}${C_WHITE}%-24s${C_RESET} %s\n" "فشلت:" "${C_RED}${COUNT_FAILED}${C_RESET}"
    printf "  ${C_BOLD}${C_WHITE}%-24s${C_RESET} %s\n" "تحذيرات:" "${C_YELLOW}${COUNT_WARNINGS}${C_RESET}"
    print_line 50
    printf "  ${C_BOLD}${C_WHITE}%-24s${C_RESET} %s\n" "حالة apt:" "${APT_STATUS}"
    printf "  ${C_BOLD}${C_WHITE}%-24s${C_RESET} %s\n" "حالة snap:" "${SNAP_STATUS}"
    printf "  ${C_BOLD}${C_WHITE}%-24s${C_RESET} %s\n" "حالة flatpak:" "${FLATPAK_STATUS}"
    printf "  ${C_BOLD}${C_WHITE}%-24s${C_RESET} %s\n" "التنظيف:" "${CLEANUP_STATUS}"
    printf "  ${C_BOLD}${C_WHITE}%-24s${C_RESET} %s\n" "إعادة تشغيل؟:" "${REBOOT_RECOMMENDED}"

    if (( ${#ERROR_LINES[@]} > 0 )); then
        echo ""
        printf "  ${C_RED}${C_BOLD}الأخطاء:${C_RESET}\n"
        for e in "${ERROR_LINES[@]}"; do
            printf "    ${C_RED}${SYM_FAIL} %s${C_RESET}\n" "${e}"
        done
    fi

    if (( ${#WARNING_LINES[@]} > 0 )); then
        echo ""
        printf "  ${C_YELLOW}${C_BOLD}التحذيرات:${C_RESET}\n"
        for w in "${WARNING_LINES[@]}"; do
            printf "    ${C_YELLOW}${SYM_WARN} %s${C_RESET}\n" "${w}"
        done
    fi

    echo ""
    if [[ -f "${LOG_FILE}" ]]; then
        printf "  ${C_GRAY}${SYM_INFO} السجل الكامل: ${LOG_FILE}${C_RESET}\n"
    fi
    log_info "═══ انتهاء التشغيل: $(date '+%Y-%m-%d %H:%M:%S %Z') ═══"
}

