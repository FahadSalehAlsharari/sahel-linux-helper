#  SECTION 12: cli_args
#  معالجة اوامر سطر الاوامر
# ----------------------------------------------------------------------------

_cli_help() {
    cat <<HELP

  ${SAHEL_NAME_AR} (${SAHEL_NAME}) v${SAHEL_VERSION}
  ${SAHEL_AUTHOR} -- ${SAHEL_SITE}

  الاستخدام:
    sahel                  الواجهة التفاعلية
    sahel --update         تحديث سريع
    sahel --clean          تنظيف سريع
    sahel --info           معلومات النظام
    sahel --self-update    تحديث الاداة نفسها
    sahel --dry-run        وضع المحاكاة (لا ينفذ شي)
    sahel --help           هذه المساعدة
    sahel --version        رقم الاصدار

  الاوضاع المركبة:
    sahel --dry-run --update    محاكاة التحديث بدون تنفيذ
    sahel --dry-run --clean     محاكاة التنظيف بدون تنفيذ

  متغيرات البيئة:
