_sysinfo_display() {
    _header
    _section "معلومات النظام"

    echo ""

    echo -e "  نظام التشغيل   : ${C_WHITE}${_OS_PRETTY:-غير معروف}${C_RESET}"
    echo -e "  نواة النظام     : ${C_WHITE}$(uname -r)${C_RESET}"
    echo -e "  المعمارية       : ${C_WHITE}$(uname -m)${C_RESET}"
    echo -e "  اسم الجهاز     : ${C_WHITE}$(hostname)${C_RESET}"

    local up
    up=$(uptime -p 2>/dev/null | sed 's/up //' || echo "غير معروف")
    echo -e "  وقت التشغيل    : ${C_WHITE}${up}${C_RESET}"

    _line '-'
    echo ""

    local cpu
    cpu=$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | xargs || echo "غير معروف")
    echo -e "  المعالج         : ${C_WHITE}${cpu}${C_RESET}"
    echo -e "  عدد الانوية     : ${C_WHITE}$(nproc 2>/dev/null || echo '?')${C_RESET}"

    if _has_cmd free; then
        local mt mu mp
        mt=$(free -h 2>/dev/null | awk '/^Mem:/{print $2}')
        mu=$(free -h 2>/dev/null | awk '/^Mem:/{print $3}')
        mp=$(free 2>/dev/null | awk '/^Mem:/{if($2>0) printf "%.0f", $3/$2*100; else print "0"}')
        echo -e "  الذاكرة (RAM)   : ${C_WHITE}${mu} / ${mt} (${mp}%)${C_RESET}"

        local st su
        st=$(free -h 2>/dev/null | awk '/^Swap:/{print $2}')
        su=$(free -h 2>/dev/null | awk '/^Swap:/{print $3}')
        if [[ -n "$st" && "$st" != "0B" && "$st" != "0" ]]; then
            echo -e "  ذاكرة التبديل   : ${C_WHITE}${su} / ${st}${C_RESET}"
        fi
    fi

    _line '-'
    echo ""

    echo -e "  ${C_CYAN}الاقراص:${C_RESET}"
    echo ""
    df -h --output=source,size,used,avail,pcent,target 2>/dev/null \
        | grep -E '^(/dev|Filesystem)' \
        | while IFS= read -r line; do
        echo -e "    ${C_DIM}${line}${C_RESET}"
    done

    _line '-'
    echo ""

    local lip
    lip=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "غير معروف")
    echo -e "  IP المحلي       : ${C_WHITE}${lip}${C_RESET}"

    _line '-'
    echo ""

    echo -e "  ${C_CYAN}مدراء الحزم:${C_RESET}"
    echo ""

    if _has_cmd apt; then
        local apt_c
        apt_c=$(dpkg --get-selections 2>/dev/null | grep -c 'install' || echo "?")
        echo -e "    ${C_GREEN}$(_icon ok)${C_RESET} apt  (${apt_c} حزمة)"
    fi

    if _snap_available; then
        local snap_c
        snap_c=$(snap list 2>/dev/null | tail -n+2 | wc -l || echo "?")
        echo -e "    ${C_GREEN}$(_icon ok)${C_RESET} snap (${snap_c} حزمة)"
    else
        echo -e "    ${C_DIM}$(_icon fail) snap (غير مثبت)${C_RESET}"
    fi

    if _flatpak_available; then
        local fp_c
        fp_c=$(flatpak list --app 2>/dev/null | wc -l || echo "?")
        echo -e "    ${C_GREEN}$(_icon ok)${C_RESET} flatpak (${fp_c} تطبيق)"
    else
        echo -e "    ${C_DIM}$(_icon fail) flatpak (غير مثبت)${C_RESET}"
    fi

    _pause
}

