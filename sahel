# إعادة تهيئة العدّادات
reset_counters() {
    COUNT_SUCCESS=0; COUNT_SKIPPED=0; COUNT_FAILED=0; COUNT_WARNINGS=0
    SUMMARY_LINES=(); WARNING_LINES=(); ERROR_LINES=()
    APT_STATUS="—"; SNAP_STATUS="—"; FLATPAK_STATUS="—"
    CLEANUP_STATUS="—"; REBOOT_RECOMMENDED="لا"
}

# ● الصيانة الآمنة (الوضع الافتراضي)
mode_safe() {
    if ! run_preflight; then
        msg_fail "فشلت فحوصات ما قبل التشغيل — لا يمكن المتابعة"
        return 1
    fi
    print_header_box "${SYM_SHIELD} الصيانة الآمنة"
    do_apt_update       || true
    do_apt_upgrade      || true
    do_snap_refresh     || true
    do_flatpak_update   || true
    do_cleanup          || true
    check_reboot_needed
    print_summary
    return 0
}

# ● المعاينة (Dry Run)
mode_preview() {
    print_header_box "${SYM_INFO} معاينة — لن يتم تنفيذ أي تغيير"
    msg_info "هذا الوضع يعرض ما يمكن عرضه بدون تعديل النظام"
    echo ""

    # apt
    msg_step "الحزم المرشحة للترقية (apt)"
    local sim
    sim=$(apt-get --simulate upgrade 2>&1) || true
    local upgradable_count
    upgradable_count=$(echo "${sim}" | grep -c "^Inst " || true)
    if (( upgradable_count > 0 )); then
        msg_info "عدد الحزم: ${upgradable_count}"
        echo "${sim}" | grep "^Inst " | head -30 | while IFS= read -r line; do
            printf "    ${C_DIM}%s${C_RESET}\n" "${line}"
        done
        if (( upgradable_count > 30 )); then
            printf "    ${C_DIM}... و %d حزمة أخرى${C_RESET}\n" "$((upgradable_count - 30))"
        fi
    else
        msg_ok "لا توجد حزم تحتاج ترقية"
    fi

    # dist-upgrade simulation
    echo ""
    msg_step "الفرق مع الترقية الكاملة (dist-upgrade)"
    local dist_sim
    dist_sim=$(apt-get --simulate dist-upgrade 2>&1) || true
    local dist_remove
    dist_remove=$(echo "${dist_sim}" | grep -c "^Remv " || true)
    local dist_new
    dist_new=$(echo "${dist_sim}" | grep -c "^Inst " || true)
    msg_info "ستُثبَّت/تُرقّى: ${dist_new} — ستُزال: ${dist_remove}"
    if (( dist_remove > 0 )); then
        msg_warn "الحزم المرشحة للإزالة:"
        echo "${dist_sim}" | grep "^Remv " | head -20 | while IFS= read -r line; do
            printf "    ${C_YELLOW}%s${C_RESET}\n" "${line}"
        done
    fi

    # autoremove simulation
    echo ""
    msg_step "الحزم المرشحة للحذف التلقائي (autoremove)"
    local ar_sim
    ar_sim=$(apt-get --simulate autoremove 2>&1) || true
    local ar_count
    ar_count=$(echo "${ar_sim}" | grep -c "^Remv " || true)
    if (( ar_count > 0 )); then
        msg_info "عدد الحزم: ${ar_count}"
        echo "${ar_sim}" | grep "^Remv " | head -20 | while IFS= read -r line; do
            printf "    ${C_DIM}%s${C_RESET}\n" "${line}"
        done
    else
        msg_ok "لا توجد حزم يمكن حذفها تلقائيًا"
    fi

    # مساحة الكاش
    echo ""
    msg_step "حجم ذاكرة التخزين المؤقت"
    local cache_size
    cache_size=$(du -sm /var/cache/apt/archives/ 2>/dev/null | awk '{print $1}' || echo "0")
    msg_info "حجم كاش apt: ${cache_size} MB"

    # نوى قديمة
    local current_kernel
    current_kernel=$(uname -r)
    local old_kernels
    old_kernels=$(dpkg -l 'linux-image-*' 2>/dev/null | awk '/^ii/{print $2}' | grep -v "${current_kernel}" | grep -v 'linux-image-generic' || true)
    if [[ -n "${old_kernels}" ]]; then
        local kcount
        kcount=$(echo "${old_kernels}" | wc -l)
        msg_info "نوى قديمة مثبتة: ${kcount}"
        echo "${old_kernels}" | while IFS= read -r k; do
            printf "    ${C_DIM}%s${C_RESET}\n" "${k}"
        done
    fi

    # حجم سجلات systemd
    if command -v journalctl &>/dev/null; then
        local journal_size
        journal_size=$(journalctl --disk-usage 2>/dev/null | grep -oP '\d+\.?\d*\s*[KMGT]' | head -1 || echo "غير معروف")
        msg_info "حجم سجلات systemd: ${journal_size}"
    fi

    # snap
    echo ""
    msg_step "حزم snap"
    if command -v snap &>/dev/null; then
        local snap_list
        snap_list=$(snap refresh --list 2>&1) || true
        if echo "${snap_list}" | grep -qi "All snaps up to date\|no updates"; then
            msg_ok "جميع حزم snap محدّثة"
        else
            msg_info "حزم snap المتاح تحديثها:"
            echo "${snap_list}" | head -20 | while IFS= read -r line; do
                printf "    ${C_DIM}%s${C_RESET}\n" "${line}"
            done
        fi
    else
        msg_info "snap غير مثبّت"
    fi

    # flatpak
    echo ""
    msg_step "حزم flatpak"
    if command -v flatpak &>/dev/null; then
        msg_info "flatpak لا يوفر وضع معاينة كامل — سيُعرض عدد التطبيقات المثبّتة فقط"
        local fp_count
        fp_count=$(flatpak list --app 2>/dev/null | wc -l || echo 0)
        msg_info "عدد تطبيقات flatpak المثبّتة: ${fp_count}"
    else
        msg_info "flatpak غير مثبّت"
    fi

    # reboot
    echo ""
    check_reboot_needed
    echo ""
    msg_info "انتهت المعاينة — لم يتم تعديل أي شيء على النظام"
    return 0
}

# ● الصيانة المتقدمة
mode_advanced() {
    echo ""
    printf "  ${C_RED}${C_BOLD}${SYM_WARN}  تحذير: الوضع المتقدم${C_RESET}\n"
    print_line 50
    printf "  ${C_YELLOW}هذا الوضع يستخدم dist-upgrade والذي قد يقوم بـ:${C_RESET}\n"
    printf "  ${C_YELLOW}  ${SYM_BULLET} تثبيت حزم جديدة لم تكن مثبتة${C_RESET}\n"
    printf "  ${C_YELLOW}  ${SYM_BULLET} إزالة حزم قائمة إذا تطلب ذلك حل التبعيات${C_RESET}\n"
    printf "  ${C_YELLOW}  ${SYM_BULLET} تغيير حالة حزم محجوزة (held)${C_RESET}\n"
    printf "  ${C_YELLOW}${SYM_WARN}  لا يتضمن do-release-upgrade ولن يغيّر إصدار أوبنتو${C_RESET}\n"
    printf "  ${C_YELLOW}${SYM_WARN}  يُنصح بتشغيل المعاينة أولاً (خيار 2)${C_RESET}\n"
    print_line 50
    echo ""

    printf "  ${C_BOLD}هل تريد المتابعة؟ (نعم/لا): ${C_RESET}"
    local confirm
    read -r confirm
    case "${confirm}" in
        نعم|y|Y|yes|YES)
            log_info "المستخدم وافق على الوضع المتقدم"
            ;;
        *)
            msg_info "تم إلغاء الوضع المتقدم"
            log_info "المستخدم ألغى الوضع المتقدم"
            return 0
            ;;
    esac

    if ! run_preflight; then
        msg_fail "فشلت فحوصات ما قبل التشغيل — لا يمكن المتابعة"
        return 1
    fi
    print_header_box "${SYM_ROCKET} الصيانة المتقدمة"
    do_apt_update           || true
    do_apt_full_upgrade     || true
    do_snap_refresh         || true
    do_flatpak_update       || true
    do_cleanup              || true
    check_reboot_needed
    print_summary
    return 0
}

# ● التنظيف فقط — لا يتطلب اتصال إنترنت
mode_cleanup_only() {
    if ! run_preflight --skip-connectivity; then
        msg_fail "فشلت فحوصات ما قبل التشغيل — لا يمكن المتابعة"
        return 1
    fi
    print_header_box "${SYM_BROOM} التنظيف فقط"
    do_cleanup || true
    check_reboot_needed
    print_summary
    return 0
}

# ● حالة النظام
mode_system_status() {
    print_header_box "${SYM_INFO} حالة النظام"
    echo ""

    # معلومات النظام
    # shellcheck source=/dev/null
    source /etc/os-release 2>/dev/null || true
    local kernel session_type de

    kernel=$(uname -r)
    session_type="${XDG_SESSION_TYPE:-غير معروف}"
    de="${XDG_CURRENT_DESKTOP:-غير معروف}"

    printf "  ${C_BOLD}${C_WHITE}%-26s${C_RESET} %s\n" "نظام التشغيل:" "${PRETTY_NAME:-غير معروف}"
    printf "  ${C_BOLD}${C_WHITE}%-26s${C_RESET} %s\n" "النواة:" "${kernel}"
    printf "  ${C_BOLD}${C_WHITE}%-26s${C_RESET} %s\n" "نوع الجلسة:" "${session_type}"
    printf "  ${C_BOLD}${C_WHITE}%-26s${C_RESET} %s\n" "سطح المكتب:" "${de}"
    printf "  ${C_BOLD}${C_WHITE}%-26s${C_RESET} %s\n" "المعمارية:" "$(dpkg --print-architecture 2>/dev/null || echo 'غير معروف')"
    printf "  ${C_BOLD}${C_WHITE}%-26s${C_RESET} %s\n" "اسم الجهاز:" "$(hostname)"

    print_line 50
    printf "  ${C_BOLD}${C_CYAN}مديرو الحزم:${C_RESET}\n"

    # apt
    if command -v apt-get &>/dev/null; then
        local apt_ver
        apt_ver=$(apt-get --version 2>/dev/null | head -1 | awk '{print $2}')
        local upgradable
        upgradable=$(apt list --upgradable 2>/dev/null | grep -c "upgradable" || echo 0)
        printf "  ${C_GREEN}${SYM_OK}${C_RESET}  %-20s %s (${upgradable} حزمة قابلة للترقية)\n" "apt:" "${apt_ver}"
    else
        printf "  ${C_RED}${SYM_FAIL}${C_RESET}  %-20s %s\n" "apt:" "غير موجود!"
    fi

    # snap
    if command -v snap &>/dev/null; then
        local snap_ver
        snap_ver=$(snap version 2>/dev/null | head -1 | awk '{print $2}')
        local snap_count
        snap_count=$(snap list 2>/dev/null | tail -n+2 | wc -l || echo 0)
        printf "  ${C_GREEN}${SYM_OK}${C_RESET}  %-20s %s (${snap_count} حزمة مثبّتة)\n" "snap:" "${snap_ver}"
    else
        printf "  ${C_GRAY}${SYM_INFO}${C_RESET}  %-20s %s\n" "snap:" "غير مثبّت"
    fi

    # flatpak
    if command -v flatpak &>/dev/null; then
        local fp_ver
        fp_ver=$(flatpak --version 2>/dev/null | awk '{print $2}')
        local fp_count
        fp_count=$(flatpak list --app 2>/dev/null | wc -l || echo 0)
        printf "  ${C_GREEN}${SYM_OK}${C_RESET}  %-20s %s (${fp_count} تطبيق)\n" "flatpak:" "${fp_ver}"
    else
        printf "  ${C_GRAY}${SYM_INFO}${C_RESET}  %-20s %s\n" "flatpak:" "غير مثبّت"
    fi

    # القرص
    print_line 50
    printf "  ${C_BOLD}${C_CYAN}استخدام القرص (/)${C_RESET}\n"
    local disk_info
    disk_info=$(df -h / | tail -1)
    local disk_total disk_used disk_avail disk_pct
    disk_total=$(echo "${disk_info}" | awk '{print $2}')
    disk_used=$(echo "${disk_info}" | awk '{print $3}')
    disk_avail=$(echo "${disk_info}" | awk '{print $4}')
    disk_pct=$(echo "${disk_info}" | awk '{print $5}')
    printf "  %-20s %s\n" "الحجم الكلي:" "${disk_total}"
    printf "  %-20s %s\n" "المستخدم:" "${disk_used} (${disk_pct})"
    printf "  %-20s %s\n" "المتاح:" "${disk_avail}"

    # شريط تقدم بسيط لاستخدام القرص
    local pct_num=${disk_pct//%/}
    local bar_width=40
    local filled=$(( pct_num * bar_width / 100 ))
    local empty=$(( bar_width - filled ))
    local bar_color="${C_GREEN}"
    if (( pct_num > 80 )); then bar_color="${C_RED}";
    elif (( pct_num > 60 )); then bar_color="${C_YELLOW}"; fi
    printf "  ["
    printf "${bar_color}"
    printf '%*s' "${filled}" '' | tr ' ' '#'
    printf "${C_GRAY}"
    printf '%*s' "${empty}" '' | tr ' ' '-'
    printf "${C_RESET}] %s\n" "${disk_pct}"

    # حجم الكاش
    print_line 50
    printf "  ${C_BOLD}${C_CYAN}أحجام التخزين المؤقت:${C_RESET}\n"
    local apt_cache_size
    apt_cache_size=$(du -sh /var/cache/apt/archives/ 2>/dev/null | awk '{print $1}' || echo "0")
    printf "  %-20s %s\n" "كاش apt:" "${apt_cache_size}"
    if command -v journalctl &>/dev/null; then
        local journal_usage
        journal_usage=$(journalctl --disk-usage 2>/dev/null | grep -oP '\d+\.?\d*\s*[KMGT]' | head -1 || echo "غير معروف")
        printf "  %-20s %s\n" "سجلات systemd:" "${journal_usage}"
    fi

    # Reboot
    print_line 50
    if [[ -f /var/run/reboot-required ]]; then
        printf "  ${C_YELLOW}${SYM_WARN} إعادة التشغيل مطلوبة${C_RESET}\n"
    else
        printf "  ${C_GREEN}${SYM_OK} لا حاجة لإعادة التشغيل${C_RESET}\n"
    fi

    # Uptime
    printf "  %-20s %s\n" "وقت التشغيل:" "$(uptime -p 2>/dev/null | sed 's/up //' || echo 'غير معروف')"
    echo ""
    return 0
}

