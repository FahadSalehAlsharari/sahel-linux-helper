    # --- Trap ---
    trap _trap_cleanup EXIT
    trap _trap_interrupt INT TERM

    # --- اوامر CLI المباشرة ---
    case "${1:-}" in
        --help|-h)
            _cli_help
            exit 0
            ;;
        --version|-v)
            _cli_version
            exit 0
            ;;
        --update)
            _safety_check_sudo
            _log_init
            _log "INFO" "=== جلسة: تحديث سريع ==="
            _safety_check_distro
            _mod_update
            exit 0
            ;;
        --clean)
            _safety_check_sudo
            _log_init
            _log "INFO" "=== جلسة: تنظيف سريع ==="
            _safety_check_distro
            _mod_cleanup
            exit 0
            ;;
        --info)
            _log_init
            _sysinfo_display
            exit 0
            ;;
        "")
            # الوضع التفاعلي
            ;;
        *)
            _err "خيار غير معروف: ${1}"
            _cli_help
            exit 1
            ;;
    esac

    # --- الوضع التفاعلي ---
    _safety_check_sudo
    _log_init
    _log "INFO" "=== بدء جلسة تفاعلية ==="
    _safety_check_distro
    _main_menu
}

main "$@"
