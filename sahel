_pkg_search() {
    _header
    _section "البحث في البرامج المثبتة"

    echo ""
    echo -ne "  اسم البرنامج (او جزء منه): "
    read -r term

    if [[ -z "$term" ]]; then
        _warn "لم يتم ادخال اسم"
        _pause
        return
    fi

    # تعقيم المدخل من الحروف الخطيرة
    term="${term//[^a-zA-Z0-9._-]/}"
    if [[ -z "$term" ]]; then
        _warn "مدخل غير صالح"
        _pause
        return
    fi

    echo ""
    _info "نتائج البحث: ${term}"
    echo ""

    local apt_r
    apt_r=$(dpkg -l 2>/dev/null | grep -i "$term" | grep '^ii' | awk '{printf "%-30s %s\n", $2, $3}')
    if [[ -n "$apt_r" ]]; then
        echo -e "  ${C_CYAN}-- apt --${C_RESET}"
        echo "$apt_r" | head -15 | while IFS= read -r l; do echo "    $l"; done
        echo ""
    fi

    if _snap_available; then
        local snap_r
        snap_r=$(snap list 2>/dev/null | grep -i "$term" || true)
        if [[ -n "$snap_r" ]]; then
            echo -e "  ${C_CYAN}-- snap --${C_RESET}"
            echo "$snap_r" | while IFS= read -r l; do echo "    $l"; done
            echo ""
        fi
    fi

    if _flatpak_available; then
        local fp_r
        fp_r=$(flatpak list --app 2>/dev/null | grep -i "$term" || true)
        if [[ -n "$fp_r" ]]; then
            echo -e "  ${C_CYAN}-- flatpak --${C_RESET}"
            echo "$fp_r" | while IFS= read -r l; do echo "    $l"; done
        fi
    fi

    _pause
}

_pkg_remove() {
    _header
    _section "حذف برنامج"

    echo ""
    echo -ne "  الاسم الدقيق للبرنامج: "
    read -r pkg

    if [[ -z "$pkg" ]]; then
        _warn "لم يتم ادخال اسم"
        _pause
        return
    fi

    # --- 0. تحقق من صلاحية الاسم ---
    _validate_pkg_name "$pkg" || { _pause; return; }

    # --- 1. فحص الحماية ---
    if _is_protected "$pkg"; then
        echo ""
        _err "هذه الحزمة محمية -- حذفها يدمر النظام"
        _err "الحزمة: ${pkg}"
        _log "WARN" "محاولة حذف حزمة محمية: ${pkg} -- مرفوض"
        _pause
        return
    fi

    # --- 2. اين الحزمة مثبتة؟ ---
    local found_apt=0 found_snap=0 found_fp=0

    _apt_is_installed "$pkg" && found_apt=1
    _snap_available && _snap_is_installed "$pkg" && found_snap=1
    _flatpak_available && _flatpak_is_installed "$pkg" && found_fp=1

    if (( found_apt + found_snap + found_fp == 0 )); then
        _err "البرنامج '${pkg}' غير مثبت"
        _info "استخدم خيار البحث [4] للتأكد من الاسم"
        _pause
        return
    fi

    local sources=""
    (( found_apt ))  && sources="${sources}apt "
    (( found_snap )) && sources="${sources}snap "
    (( found_fp ))   && sources="${sources}flatpak "
    _info "مصدر التثبيت: ${C_WHITE}${sources}${C_RESET}"

    # --- 3. تأثير الحذف (apt) ---
    local do_purge=0
    if (( found_apt )); then
        echo ""
        echo -e "  ${C_YELLOW}الحزم التي ستتأثر:${C_RESET}"

        local impact blocked=0
        if ! impact=$(_apt_removal_impact "$pkg"); then
            _err "تعذر حساب التأثير"
            _pause
            return
        fi

        while IFS= read -r affected; do
            [[ -z "$affected" ]] && continue
            if _is_protected "$affected"; then
                echo -e "    ${C_RED}$(_icon fail) ${affected} [محمية -- يتم الالغاء]${C_RESET}"
                blocked=1
            else
                echo -e "    ${C_DIM}- ${affected}${C_RESET}"
            fi
        done <<< "$impact"

        if (( blocked )); then
            echo ""
            _err "الحذف يمس حزمة اساسية محمية -- تم الالغاء تلقائيا"
            _log "WARN" "حذف ${pkg} يمس حزمة محمية -- ملغي"
            _pause
            return
        fi

        # سؤال عن purge
        echo ""
        echo -e "  ${C_CYAN}نوع الحذف:${C_RESET}"
        echo -e "    ${C_WHITE}1${C_RESET} -- حذف عادي (remove) -- يبقي ملفات الاعدادات"
        echo -e "    ${C_WHITE}2${C_RESET} -- حذف كامل (purge)  -- يحذف كل شي"
        echo -ne "  الاختيار [1]: "
        read -r ptype
        [[ "$ptype" == "2" ]] && do_purge=1
    fi

    # --- 4. تأكيد مزدوج ---
    local purge_note=""
    (( do_purge )) && purge_note=" (مع ملفات الاعدادات)"
    if ! _confirm_danger "سيتم حذف '${pkg}'${purge_note} نهائيا. هذا الاجراء قد لا يمكن التراجع عنه."; then
        _info "تم الالغاء"
        _pause
        return
    fi

    # --- 5. تنفيذ ---
    (( found_apt ))  && _apt_remove "$pkg" "$do_purge"
    (( found_snap )) && _snap_remove "$pkg"
    (( found_fp ))   && _flatpak_remove "$pkg"

    _pause
}

# ========================================
#  تثبيت برامج جديدة
# ========================================
_mod_install() {
    while true; do
        _header
        _section "تثبيت برامج جديدة"

        echo ""
        echo -e "  ${C_WHITE}1${C_RESET} -- البحث والتثبيت عبر apt"
        echo -e "  ${C_WHITE}2${C_RESET} -- البحث والتثبيت عبر Snap"
        echo -e "  ${C_WHITE}3${C_RESET} -- برامج شائعة (قائمة جاهزة)"
        echo ""
        echo -e "  ${C_WHITE}0${C_RESET} -- رجوع"
        echo ""
        echo -ne "  الاختيار: "
        read -r c

        case "$c" in
            1) _install_from_apt ;;
            2) _install_from_snap ;;
            3) _install_popular ;;
            0) return ;;
            *) _warn "اختيار غير صحيح"; sleep 1 ;;
        esac
    done
}

_install_from_apt() {
    _header
    _section "البحث في مستودعات apt"

    echo ""
    echo -ne "  اسم البرنامج: "
    read -r term

    [[ -z "$term" ]] && { _warn "لم يتم ادخال اسم"; _pause; return; }

    # تعقيم المدخل
    term="${term//[^a-zA-Z0-9._-]/}"
    [[ -z "$term" ]] && { _warn "مدخل غير صالح"; _pause; return; }

    _info "جاري البحث..."
    echo ""

    local results
    results=$(_apt_search "$term")

    if [[ -z "$results" ]]; then
        _err "لا توجد نتائج: ${term}"
        _pause
        return
    fi

    local i=1
    while IFS= read -r line; do
        local name desc
        name=$(echo "$line" | awk '{print $1}')
        desc=$(echo "$line" | cut -d' ' -f3-)
        printf "  ${C_WHITE}%2d${C_RESET}  %-28s ${C_DIM}%s${C_RESET}\n" "$i" "$name" "${desc:0:38}"
        (( i++ ))
    done <<< "$results"

    echo ""
    echo -ne "  رقم البرنامج (0 = رجوع): "
    read -r sel

    [[ "$sel" == "0" || -z "$sel" ]] && return
    _is_int "$sel" || { _warn "رقم غير صحيح"; _pause; return; }

    local chosen
    chosen=$(echo "$results" | sed -n "${sel}p" | awk '{print $1}')
    [[ -z "$chosen" ]] && { _warn "خارج النطاق"; _pause; return; }

    echo ""
    _info "تفاصيل: ${chosen}"
    _apt_show_pkg "$chosen" | while IFS= read -r l; do
        echo -e "    ${C_DIM}${l}${C_RESET}"
    done

    if _confirm "تثبيت ${chosen}؟"; then
        _apt_install "$chosen"
    fi
    _pause
}

_install_from_snap() {
    _header
    _section "البحث في متجر Snap"

    if ! _snap_available; then
        _info "Snap غير مثبت"
        if _confirm "تثبيت snapd؟"; then
            _apt_install "snapd"
        fi
        _pause
        return
    fi

    echo ""
    echo -ne "  اسم البرنامج: "
    read -r term

    [[ -z "$term" ]] && { _warn "لم يتم ادخال اسم"; _pause; return; }

    # تعقيم المدخل
    term="${term//[^a-zA-Z0-9._-]/}"
    [[ -z "$term" ]] && { _warn "مدخل غير صالح"; _pause; return; }

    _info "جاري البحث..."
    echo ""

    snap find "$term" 2>/dev/null | head -12 | while IFS= read -r l; do
        echo -e "    ${C_DIM}${l}${C_RESET}"
    done

    echo ""
    echo -ne "  اسم البرنامج الدقيق للتثبيت (0 = رجوع): "
    read -r pkg

    [[ "$pkg" == "0" || -z "$pkg" ]] && return

    if _confirm "تثبيت '${pkg}' عبر Snap؟"; then
        _log "INFO" "snap install ${pkg}"
        if (( SAHEL_DRY_RUN )); then
            _dry "snap install ${pkg}"
        elif _as_root snap install "$pkg" 2>&1 | tail -3; then
            _ok "تم تثبيت ${pkg}"
            _log "INFO" "snap install ${pkg} -- نجح"
        else
            _err "فشل تثبيت ${pkg}"
            _log "ERROR" "snap install ${pkg} -- فشل"
        fi
    fi
    _pause
}

# --- تحميل البرامج الشائعة من ملف خارجي او القيم الافتراضية ---
_load_popular_categories() {
    # لو فيه ملف اعدادات خارجي نقرأ منه
    if [[ -f "$SAHEL_POPULAR_CONF" ]]; then
        _log "INFO" "تحميل قائمة البرامج الشائعة من ${SAHEL_POPULAR_CONF}"
        return 0
    fi
    return 1
}

_install_popular() {
    _header
    _section "برامج شائعة"

    echo ""
    echo -e "  ${C_WHITE}1${C_RESET} -- متصفحات"
    echo -e "  ${C_WHITE}2${C_RESET} -- برامج مكتبية"
    echo -e "  ${C_WHITE}3${C_RESET} -- مشغلات وسائط"
    echo -e "  ${C_WHITE}4${C_RESET} -- ادوات تطوير"
    echo -e "  ${C_WHITE}5${C_RESET} -- ادوات نظام"
    echo ""
    echo -e "  ${C_WHITE}0${C_RESET} -- رجوع"
    echo ""
    echo -ne "  الاختيار: "
    read -r cat

    local -a names=() descs=()

    # محاولة تحميل القوائم من ملف خارجي
    # الصيغة في popular.conf:
    #   [browsers]
    #   firefox=Firefox -- متصفح مفتوح المصدر
    #   chromium-browser=Chromium -- متصفح مفتوح المصدر
    if _load_popular_categories; then
        local section_name=""
        case "$cat" in
            1) section_name="browsers"   ;;
            2) section_name="office"     ;;
            3) section_name="media"      ;;
            4) section_name="dev"        ;;
            5) section_name="systools"   ;;
            0) return ;;
            *) _warn "اختيار غير صحيح"; _pause; return ;;
        esac

        local in_section=0
        while IFS= read -r line; do
            # تخطي التعليقات والسطور الفارغة
            [[ -z "$line" || "$line" =~ ^# ]] && continue
            if [[ "$line" =~ ^\[(.+)\]$ ]]; then
                [[ "${BASH_REMATCH[1]}" == "$section_name" ]] && in_section=1 || in_section=0
                continue
            fi
            if (( in_section )); then
                local pname="${line%%=*}"
                local pdesc="${line#*=}"
                names+=("$pname")
                descs+=("$pdesc")
            fi
        done < "$SAHEL_POPULAR_CONF"
    fi

    # لو القوائم فاضية (ما فيه ملف او القسم فاضي) -- استخدم الافتراضي
    if (( ${#names[@]} == 0 )); then
        case "$cat" in
            1)
                names=("firefox" "chromium-browser")
                descs=("Firefox -- متصفح مفتوح المصدر" "Chromium -- متصفح مفتوح المصدر")
                ;;
            2)
                names=("libreoffice" "thunderbird" "evince")
                descs=("LibreOffice -- بديل مايكروسوفت اوفيس" "Thunderbird -- بريد الكتروني" "Evince -- عارض PDF")
                ;;
            3)
                names=("vlc" "mpv" "audacity")
                descs=("VLC -- مشغل فيديو شامل" "mpv -- مشغل خفيف" "Audacity -- محرر صوت")
                ;;
            4)
                names=("git" "curl" "build-essential" "python3-pip")
                descs=("Git -- ادارة اكواد" "cURL -- نقل بيانات" "GCC/make -- ادوات بناء" "pip -- مدير حزم بايثون")
                ;;
            5)
                names=("htop" "neofetch" "net-tools" "tree" "ncdu")
                descs=("htop -- مراقب موارد" "neofetch -- معلومات نظام" "net-tools -- ادوات شبكة" "tree -- عرض مجلدات" "ncdu -- تحليل قرص")
                ;;
            0) return ;;
            *) _warn "اختيار غير صحيح"; _pause; return ;;
        esac
    fi

    echo ""
    for i in "${!names[@]}"; do
        local st
        if _apt_is_installed "${names[$i]}"; then
            st="${C_GREEN}[مثبت]${C_RESET}"
        else
            st="${C_DIM}[غير مثبت]${C_RESET}"
        fi
        printf "  ${C_WHITE}%d${C_RESET}  %-40s %b\n" "$((i+1))" "${descs[$i]}" "$st"
    done

    echo ""
    echo -ne "  رقم البرنامج (0 = رجوع): "
    read -r sel

    [[ "$sel" == "0" || -z "$sel" ]] && return
    _is_int "$sel" || { _warn "رقم غير صحيح"; _pause; return; }

    local idx=$((sel - 1))
    if (( idx < 0 || idx >= ${#names[@]} )); then
        _warn "خارج النطاق"
        _pause
        return
    fi

    local pkg="${names[$idx]}"

    if _apt_is_installed "$pkg"; then
        _info "${pkg} مثبت مسبقا"
        _pause
        return
    fi

    if _confirm "تثبيت ${pkg}؟"; then
        _apt_install "$pkg"
    fi
    _pause
}

# ----------------------------------------------------------------------------
#  SECTION 11: self_update
#  تحديث الاداة ذاتيا
# ----------------------------------------------------------------------------

_mod_self_update() {
    _header
    _section "تحديث ${SAHEL_NAME_AR}"

    if ! _has_cmd curl && ! _has_cmd wget; then
        _err "يحتاج curl او wget -- ثبت واحد منهم اولا"
        _pause
        return
    fi

    local script_path
    script_path="$(readlink -f "$0" 2>/dev/null || echo "$0")"

    if [[ ! -w "$script_path" ]]; then
        _err "لا يمكن الكتابة على: ${script_path}"
        _info "جرب التشغيل بصلاحيات sudo"
        _pause
        return
    fi

    local raw_url="${SAHEL_REPO}/raw/main/sahel"
    _info "التحقق من التحديثات..."
    _info "المصدر: ${raw_url}"

    local tmp_file
    tmp_file=$(mktemp /tmp/sahel-update.XXXXXX) || { _err "تعذر انشاء ملف مؤقت"; _pause; return; }

    # تنظيف الملف المؤقت عند الخروج من الدالة
    trap 'rm -f "$tmp_file"' RETURN

    local dl_ok=0
    if _has_cmd curl; then
        curl -fsSL --max-time 30 "$raw_url" -o "$tmp_file" 2>/dev/null && dl_ok=1
    elif _has_cmd wget; then
        wget -q --timeout=30 "$raw_url" -O "$tmp_file" 2>/dev/null && dl_ok=1
    fi

    if (( ! dl_ok )) || [[ ! -s "$tmp_file" ]]; then
        _err "فشل تحميل التحديث"
        _info "تأكد من الاتصال بالانترنت والرابط: ${raw_url}"
        _pause
        return
    fi

    # استخراج الاصدار من الملف المحمل
    local remote_ver
    remote_ver=$(grep -m1 '^SAHEL_VERSION=' "$tmp_file" | cut -d'"' -f2 || echo "")

    if [[ -z "$remote_ver" ]]; then
        _err "الملف المحمل لا يبدو ملف sahel صالح"
        _pause
        return
    fi

    if [[ "$remote_ver" == "$SAHEL_VERSION" ]]; then
        _ok "انت على اخر اصدار: v${SAHEL_VERSION}"
        _pause
        return
    fi

    _info "الاصدار الحالي : v${SAHEL_VERSION}"
    _info "الاصدار الجديد : v${remote_ver}"

    if ! _confirm "تحديث الى v${remote_ver}؟"; then
        _info "تم الالغاء"
        _pause
        return
    fi

    if (( SAHEL_DRY_RUN )); then
        _dry "cp ${tmp_file} ${script_path}"
        _pause
        return
    fi

    # نسخة احتياطية
    cp "$script_path" "${script_path}.bak" 2>/dev/null || true

    # استبدال
    if cp "$tmp_file" "$script_path" && chmod +x "$script_path"; then
        _ok "تم التحديث الى v${remote_ver}"
        _info "نسخة احتياطية: ${script_path}.bak"
        _log "INFO" "self-update: ${SAHEL_VERSION} -> ${remote_ver}"
        _info "اعد تشغيل الاداة لتطبيق التحديث"
    else
        _err "فشل نسخ الملف -- استعادة النسخة الاحتياطية"
        cp "${script_path}.bak" "$script_path" 2>/dev/null || true
    fi

    _pause
}

